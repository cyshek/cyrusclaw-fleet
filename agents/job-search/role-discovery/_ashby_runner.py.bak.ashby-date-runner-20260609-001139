                            fid = item['fid']
                            val = text_fields.get(fid, '')
                            dom_id = item.get('dom_id') or item.get('fid') or fid
                            if not val:
                                continue
                            cur = page.evaluate(f"() => {{const e = document.getElementById({json.dumps(dom_id)}); return e ? e.value : null;}}")
                            # chain_036: Snowflake-class autofill resets React's
                            # CONTROLLED state to empty while leaving the DOM .value
                            # intact -> server reports required field missing even
                            # though cur==val. So for core identity/required fields
                            # (name/email/phone), ALWAYS re-fire the native setter to
                            # force a React onChange commit, even when cur==val.
                            low = (item.get('label','') + ' ' + str(fid)).lower()
                            force = any(k in low for k in ('name','email','phone','systemfield'))
                            if cur == val and not force:
                                continue
                            try:
                                res = page.evaluate(_SET_VALUE_JS, {"id": dom_id, "val": val})
                                if isinstance(res, dict) and res.get('ok'):
                                    final_retyped.append(fid)
                            except Exception as e:
                                log(f"final retype fail on {dom_id}: {e}")
                        if final_retyped:
                            result['steps'].append({'i':i,'tool':'final-retype','count':len(final_retyped),'fields':final_retyped})
                        # chain_035: autofill ALSO clobbers (a) required-ack checkboxes
                        # and (b) empty-id text inputs. The post-upload retype above only
                        # restores id-resolvable text + radios. Re-run checkbox-ack and
                        # the [data-field-path] text fallback here, post-settle.
                        import re as _re35
                        _uuidR = _re35.compile(r'[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}', _re35.I)
                        # re-fill empty-id text fields via container
                        for fid, val in text_fields.items():
                            if not val:
                                continue
                            uu = _uuidR.findall(fid)
                            if not uu:
                                continue
                            tail = uu[-1]
                            sel = f'[data-field-path="{tail}"] input:not([type=radio]):not([type=checkbox]):not([type=file]), [data-field-path="{tail}"] textarea'
                            try:
                                loc = page.locator(sel).first
                                if loc.count() == 0:
                                    continue
                                # chain_036: do NOT skip when input_value()==val.
                                # Snowflake-class autofill leaves the DOM .value intact
                                # while resetting React's controlled state to empty, so
                                # the server still sees the field as missing. Always
                                # re-type via real keystrokes (Playwright keyboard fires
                                # genuine input/change that React commits).
                                loc.scroll_into_view_if_needed(timeout=1500)
                                loc.click(timeout=2000)
                                page.keyboard.press('Control+a'); page.keyboard.press('Delete')
                                page.keyboard.type(val, delay=8)
                                page.keyboard.press('Tab')
                                log(f"post-upload text-fallback {tail[-12:]}")
                            except Exception:
                                pass
                        # re-check ack checkboxes (find the checkbox-resolve eval step)
                        for j in range(i):
                            sj2 = steps[j]
                            fnj = sj2.get('args', {}).get('fn', '') if sj2.get('tool') == 'browser.act.evaluate' else ''
                            if 'input[type=checkbox]' in fnj and 'const __payload = [' in fnj:
                                pmj = _re35.search(r'const __payload = (\[.*?\]); return', fnj, _re35.S)
                                if not pmj:
                                    continue
                                try:
                                    cbpay = json.loads(pmj.group(1))
                                except Exception:
                                    continue
                                for e3 in cbpay:
                                    wn = e3.get('name', '')
                                    vals3 = e3.get('values') or []
                                    wt = vals3[0] if vals3 else ''
                                    try:
                                        ar = page.evaluate(_CHECKBOX_ACK_JS, {"want_name": wn, "want_text": wt})
                                        log(f"post-upload checkbox-ack {wn[-12:]}: {ar.get('checked') if isinstance(ar,dict) else ar}")
                                    except Exception:
                                        pass
                                    page.wait_for_timeout(120)
                except Exception as e:
                    result['steps'].append({'i':i,'tool':tool,'err':str(e)})
                    log(f"upload fail: {e}")
            elif tool == 'ashby.maybe_solve_recaptcha_v3':
                if no_captcha:
                    result['steps'].append({'i':i,'tool':tool,'skipped':'no-captcha-flag'})
                    continue
                sitekey = (args.get('sitekey_fallback')
                           or args.get('known_strict_sitekey')
                           or (args.get('driver_exec', {}).get('kwargs', {}) or {}).get('fallback_sitekey'))
                page_url = args.get('page_url')
                # CapSolver scores the token against the page where it is
                # generated. The Ashby grecaptcha.execute() runs on the
                # /application page, so the score is computed for THAT url. The
                # plan may carry the bare JD url; normalize to /application.
                try:
                    cur_url = page.url
                    if cur_url and '/application' in cur_url:
                        page_url = cur_url
                    elif page_url and not page_url.rstrip('/').endswith('/application'):
                        page_url = page_url.rstrip('/') + '/application'
                except Exception:
                    if page_url and not page_url.rstrip('/').endswith('/application'):
                        page_url = page_url.rstrip('/') + '/application'
                # TOOLS.md (chain_032): the Ashby app bundle calls
                # grecaptcha.execute(sitekey, {action: "job_apply"}). The token's
                # action MUST match what the server verifies. The plan emitter
                # historically wrote page_action="submit" (wrong for Ashby), so
                # force job_apply here regardless of the stale plan value.
                action = 'job_apply'
                # Live sitekey detection beats any hardcoded fallback: scrape the
                # recaptcha loader's ?render=<sitekey> from the page scripts.
                try:
                    live_sk = page.evaluate("() => { const s = Array.from(document.scripts).map(x=>x.src).find(u=>/recaptcha\\/(api|enterprise)\\.js/.test(u||'')); if(!s) return null; const m = s.match(/[?&]render=([^&]+)/); return m ? m[1] : null; }")
                    if live_sk and live_sk != 'explicit':
                        sitekey = live_sk
                        log(f"live recaptcha sitekey detected: {live_sk[:18]}...")
                except Exception as e:
                    log(f"live sitekey probe fail: {e}")
                # Detect: confirm v3 is present
                detect_js = args.get('detect_fn', '').strip()
                if detect_js:
                    det = page.evaluate(f"({detect_js})()")
                else:
                    det = None
                if not sitekey:
                    log("no sitekey, skip captcha"); result['steps'].append({'i':i,'tool':tool,'skipped':'no-sitekey'}); continue
                t0 = time.monotonic()
                try:
                    # 2026-06-03 RESIDENTIAL-IP FIX: when the submit browser is
                    # already egressing through a residential proxy (JOBSEARCH_CDP
                    # points at the proxied Chrome), generate the v3 token IN-PAGE
                    # via grecaptcha.execute(). That token is bound to the SAME
                    # residential IP/session the form submits from -> reCAPTCHA-v3
                    # sees one consistent trusted IP (page-load + token + submit),
                    # which the Proxyless 2Captcha/CapSolver farm-IP token never
                    # achieved (that was the real cause of the persistent
                    # RECAPTCHA_SCORE_BELOW_THRESHOLD). Free, no solver call.
                    # Falls through to the solver loop if grecaptcha isn't ready.
                    token = None
                    _cerrs = {}
                    if _os.environ.get('JOBSEARCH_INBROWSER_V3', '1') != '0':
                        try:
                            token = page.evaluate(
                                """([sk, act]) => new Promise((res)=>{
                                  try{
                                    const g = (window.grecaptcha && window.grecaptcha.enterprise && window.grecaptcha.enterprise.execute)
                                              ? window.grecaptcha.enterprise : window.grecaptcha;
                                    if(!g || !g.execute){ res(null); return; }
                                    g.ready(()=>{ g.execute(sk,{action:act}).then(t=>res(t||null)).catch(()=>res(null)); });
                                    setTimeout(()=>res(null), 12000);
                                  }catch(e){ res(null); }
                                })""",
                                [sitekey, action])
                            if token:
                                log(f"recaptcha-v3 generated IN-BROWSER (residential), len={len(token)}")
                        except Exception as _eb:
                            log(f"in-browser v3 exec failed: {_eb}")
                            token = None
                    # 2026-06-03: prefer 2Captcha (CapSolver v3 still works but
                    # 2Captcha is the funded primary). Fall back to capsolver.
                    if not token:
                        for _vend in ('twocaptcha', 'capsolver'):
                            try:
                                token = CaptchaSolver(vendor=_vend).solve_recaptcha_v3(
                                    sitekey, page_url, page_action=action)
                                log(f"recaptcha-v3 solved via {_vend}")
                                break
                            except Exception as _ev:
                                _cerrs[_vend] = str(_ev)
                                log(f"recaptcha-v3 {_vend} failed: {_ev}")
                    if not token:
                        raise RuntimeError('; '.join(f'{k}={v}' for k,v in _cerrs.items()))
                except Exception as e:
                    log(f"captcha solve fail: {e}")
                    result['steps'].append({'i':i,'tool':tool,'err':f'solve_fail:{e}'})
                    captcha_token = None
                    continue
                elapsed = time.monotonic() - t0
                log(f"captcha v3 solved in {elapsed:.1f}s, token len={len(token)}")
                # Inject
                inject_js = args.get('inject_fn', '').strip()
                if inject_js:
                    inj = page.evaluate(f"({inject_js})({json.dumps(token)})")
                else:
                    # Ashby uses SUFFIXED textareas (g-recaptcha-response-100000),
                    # not just the bare id. Inject into every recaptcha-response
                    # slot present, and create the canonical ids if missing.
                    _inject_fn = (
                        "(t) => {"
                        "  const slots = new Set(['g-recaptcha-response','g-recaptcha-response-100000']);"
                        "  document.querySelectorAll('textarea[id^=g-recaptcha-response],textarea[name^=g-recaptcha-response]').forEach(e=>{ if(e.id) slots.add(e.id); });"
                        "  let n=0;"
                        "  for (const id of slots){ let el=document.getElementById(id); if(!el){ el=document.createElement('textarea'); el.id=id; el.name=id; el.style.display='none'; document.body.appendChild(el);} el.value=t; n++; }"
                        "  return {injected:n, ids:[...slots]};"
                        "}"
                    )
                    inj = page.evaluate(f"({_inject_fn})({json.dumps(token)})")
                captcha_token = token
                result['steps'].append({'i':i,'tool':tool,'solve_ms':int(elapsed*1000),'token_len':len(token),'inject':inj,'detect':det})
            else:
                log(f"UNKNOWN STEP TOOL: {tool}")
                result['steps'].append({'i':i,'tool':tool,'skipped':'unknown'})
            # Stop early on no-submit
            if no_submit and args.get('meta',{}).get('final_submit'):
                result['steps'].append({'i':i,'tool':'final_submit-SKIPPED'})
                break
    finally:
        # Don't close the page yet — let caller inspect
        time.sleep(0.5)
        try: page.close()
        except: pass
        try: browser.close()
        except: pass
        pw.stop()
    return result

if __name__ == '__main__':
    plan = sys.argv[1]
    no_submit = '--no-submit' in sys.argv
    no_captcha = '--no-captcha' in sys.argv
    r = run_plan(plan, no_submit=no_submit, no_captcha=no_captcha)
    print(json.dumps(r, indent=2, default=str))
    sys.exit(0 if r['ok'] else 1)
