# chain_p12 (2026-06-08, Benchling 2658): TWO additive pre-submit fixes for the
# Ashby autofill/regenerated-entry-UUID clobber class that the earlier guard
# missed:
#   (A) Work-auth radio whose live container data-field-path carries a FRESH
#       entry-UUID (regenerated on page load) that the plan's stale-UUID
#       field-path candidates fail to `[data-field-path="..."]`-match exactly,
#       so the work-auth option never re-commits -> POST banks "Missing entry
#       for required field: ...Work Authorization...". Fix: locate the container
#       by LABEL needle (UUID-independent) and trusted-commit the radio whose
#       label matches the desired value.
#   (B) In-office / hybrid / relocation questions Ashby renders as a required
#       CHECKBOX group (e.g. "Are you able to work from our office Mon/Tue/Thu"
#       -> options Yes / No / I'd like to discuss). The static dry-run only
#       enumerates radios + yes/no widgets, so these checkbox-questions are
#       NEVER in the plan and submit banks "Missing entry for required field".
#       Fix: check the affirmative ("Yes") option per in-office/relocate doctrine.
# Both are STRICTLY ADDITIVE + idempotent: they only act on a container that is
# (label-matched) AND currently has NO option selected, so they are a no-op for
# tenants/rows without these exact fields (safe for the rest of the cohort).
_DOCTRINE_CHOICE_FIX_JS = r"""(args) => {
  const out = {workauth: null, inoffice: null};
  const fire = (el) => {
    try {
      const proto = el.type === 'checkbox' ? HTMLInputElement.prototype : HTMLInputElement.prototype;
      const setter = Object.getOwnPropertyDescriptor(proto, 'checked');
      if (setter && setter.set) setter.set.call(el, true); else el.checked = true;
      el.dispatchEvent(new MouseEvent('click', {bubbles:true}));
      el.dispatchEvent(new Event('input', {bubbles:true}));
      el.dispatchEvent(new Event('change', {bubbles:true}));
    } catch(e) {}
  };
  const labelFor = (el) => {
    if (!el.id) return '';
    const l = document.querySelector('label[for="' + el.id.replace(/"/g,'') + '"]');
    return (l ? l.innerText : '').trim();
  };
  const conts = [...document.querySelectorAll('[data-field-path], div[class*=_fieldEntry_], fieldset')];
  // (A) work-auth radio by label needle.
  const WA = /authoriz|authoris|eligib|legally|work in the u|right to work/;
  for (const c of conts) {
    const lbl = ((c.querySelector('label, legend')||{}).innerText||'').toLowerCase();
    if (!WA.test(lbl)) continue;
    const radios = [...c.querySelectorAll('input[type=radio]')];
    if (!radios.length) continue;
    if (radios.some(r => r.checked)) { out.workauth = {already:true}; break; }
    const want = (args.workauth_value || '').toLowerCase();
    let pick = radios.find(r => labelFor(r).toLowerCase() === want)
            || radios.find(r => want && labelFor(r).toLowerCase().includes(want))
            || radios.find(r => /any employer|authorized to work|u\.?s\.? citizen|yes/.test(labelFor(r).toLowerCase()));
    if (pick) { fire(pick); out.workauth = {checked:true, label:labelFor(pick)}; }
    break;
