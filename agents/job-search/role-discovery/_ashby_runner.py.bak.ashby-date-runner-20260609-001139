def final_clobber_guard(page, plan, steps, settle_max_ms=6000, settle_quiet_ms=1200):
    """chain_p11: settle-then-reassert Location typeahead + work-auth radio as the
    LAST action before submit, to beat the Ashby resume-autofill's final clobber.
    Returns a status dict {settled, location_value, location_ok, workauth_checked,
    refilled_location, reasserted_workauth}. Never raises."""
    status = {'settled': False, 'location_value': None, 'location_ok': None,
              'workauth_checked': None, 'refilled_location': None,
              'reasserted_workauth': []}
    # 1) Deterministic settle: wait for the autofill's last mutation (capped).
    try:
        status['settled'] = wait_autofill_settle(page, max_ms=settle_max_ms, quiet_ms=settle_quiet_ms)
    except Exception as e:
        log(f"final-guard settle fail: {e}")
    # 2) Re-fill the Location typeahead with PROPER option-SELECTION (not the
    #    free-text-tab fast path, which leaves visible text the form serializer
    #    rejects as empty -> "Missing entry for required field: Location"). The
    #    location_typeahead_v2 step often falls back to free-text-tab when Ashby's
    #    async geo lookup is slow; here we use _LOCATION_COMBO_FILL_JS which waits
    #    for the geo options and CLICKS a matching one (integrity-guarded). Verify
    #    non-empty after; retry once if still blank.
    _loc_value = None
    _loc_tail = None
    try:
        # Discover the Location field's value + field-path tail from the plan's
        # location_typeahead_v2 payload (fid like '<...>__systemfield_location').
        loc_step = next((st for st in steps
            if st.get('tool') == 'browser.act.evaluate'
            and st.get('args', {}).get('meta', {}).get('location_typeahead_v2')), None)
        if loc_step:
            import re as _re11
            _m = _re11.search(r'"fid":\s*"([^"]+)"', loc_step['args']['fn'])
            _mv = _re11.search(r'"value":\s*"([^"]+)"', loc_step['args']['fn'])
            if _m:
                _fid = _m.group(1)
                # tail = portion after the form-id underscore split that ends the fid;
                # _LOCATION_COMBO_FILL_JS matches on data-field-path.endsWith(tail).
                _loc_tail = _fid.split('_', 1)[1] if '_' in _fid else _fid
            if _mv:
                _loc_value = _mv.group(1)
    except Exception as e:
        log(f"final-guard location-step parse fail: {e}")
    _loc_value = _loc_value or 'Kirkland, WA'
    _loc_tail = _loc_tail or '__systemfield_location'
    status['_loc_value'] = _loc_value
    status['_loc_tail'] = _loc_tail
    for _attempt in range(2):
        try:
            status['refilled_location'] = page.evaluate(
                f"(args) => ({_LOCATION_COMBO_FILL_JS})(args)",
                {'tail': _loc_tail, 'value': _loc_value})
            page.wait_for_timeout(350)
        except Exception as e:
            log(f"final-guard location combo-fill fail (attempt {_attempt+1}): {e}")
            status['refilled_location'] = {'ok': False, 'reason': f'eval-threw:{e}'}
        # Quick verify; break if the field is now non-empty.
        try:
            _v = page.evaluate(_VERIFY_LOC_WORKAUTH_JS)
            if isinstance(_v, dict) and (_v.get('location') or '').strip():
                break
        except Exception:
            break
        page.wait_for_timeout(250)
    # 3) Re-assert work-auth radio(s) via TRUSTED click. Identify work-auth-class
    #    radio entries in the plan by label keywords, then trusted-click the
    #    truthful option in its own container (registers in React).
    _WA_RE = ('authoriz', 'authoris', 'eligib', 'legally', 'work in the u',
              'right to work', 'visa', 'sponsor')
    for rd in (plan.get('radios') or []):
        try:
            lbl = (rd.get('label') or '').lower()
            if not any(k in lbl for k in _WA_RE):
                continue
            name = rd.get('name') or ''
            want = (rd.get('value') or '').strip()
            opts = [o for o in (rd.get('options') or []) if isinstance(o, str) and o.strip()]
            # Locate the field container.
            cand_paths = _field_path_candidates(name)
            cont = None
            for cp in cand_paths:
                try:
                    el = page.query_selector(f'[data-field-path="{cp}"]')
                except Exception:
                    el = None
                if el:
                    cont = el
                    break
            if cont is None:
                continue
            opt_labels = []
            for _lab in cont.query_selector_all('label'):
                _t = (_lab.inner_text() or '').strip()
                if _t:
                    opt_labels.append(_t)
            tgt = choose_select_option(want, opt_labels or opts, rd.get('label', '')) or want
            tl = (tgt or '').strip().lower()
            clicked = False
            for _lab in cont.query_selector_all('label'):
                _lt = (_lab.inner_text() or '').strip().lower()
                if _lt and (_lt == tl or tl in _lt):
                    try:
                        _lab.scroll_into_view_if_needed(timeout=1500)
                        _lab.click(timeout=2500)
                        clicked = True
                    except Exception:
                        pass
                    break
            # chain_p11b (2026-06-08): some Ashby tenants (Klarity 1434) ignore a
            # plain Playwright label.click() for radio options -- the click lands
            # but React onChange never fires, so the option reads UNCHECKED at
            # submit and the POST banks "Missing entry for required field". Force-
            # commit the matched option via a TRUSTED pointer sequence + native
            # checked-setter + input/change events (same mechanism as
            # _RADIO_CLICK_BY_ID_JS). Idempotent + never raises.
            committed = None
            try:
                committed = page.evaluate(_RADIO_FORCE_COMMIT_IN_CONTAINER_JS,
                                          {'field_paths': _field_path_candidates(name),
                                           'target': tgt})
                if isinstance(committed, dict) and committed.get('checked'):
                    clicked = True
            except Exception as _e:
                log(f"final-guard radio force-commit fail for {name[-20:]}: {_e}")
            status['reasserted_workauth'].append({'name': name[-24:], 'target': tgt, 'clicked': clicked, 'committed': committed})
        except Exception as e:
            log(f"final-guard workauth reassert fail for {(rd.get('name') or '')[-20:]}: {e}")
    # 4) STABILITY GATE + same-tick verification. The autofill can re-clobber
    #    Location in a microtask AFTER our refill+verify but BEFORE the submit
    #    serialize (observed on Rogo 2903: verify read location_ok=True yet the
    #    submit body still showed "Parsing your resume. Autofilling key fields..."
    #    and the POST returned the Location error). Defend by: (a) waiting for the
    #    "Parsing..." banner to clear, (b) re-picking Location if it went blank,
    #    and (c) requiring Location to read non-empty on TWO consecutive checks
    #    (stable) before we let the caller submit. Capped, deterministic.
    def _loc_now():
        try:
            v = page.evaluate(_VERIFY_LOC_WORKAUTH_JS)
            if isinstance(v, dict):
                return v
        except Exception as e:
            log(f"final-guard verify fail: {e}")
        return {}
    def _parsing_up():
        try:
            return bool(page.evaluate(
                "() => /parsing your resume|autofilling key fields/i.test(document.body.innerText||'')"))
        except Exception:
            return False
    _consec_ok = 0
    _last_v = {}
    _wa_radio_specs = []
    for _rd in (plan.get('radios') or []):
        _l = (_rd.get('label') or '').lower()
        if any(k in _l for k in _WA_RE):
            _vv = (_rd.get('value') or '').strip()
            _oo = [o for o in (_rd.get('options') or []) if isinstance(o, str) and o.strip()]
            _tgt = choose_select_option(_vv, _oo, _rd.get('label', '')) or _vv
            _wa_radio_specs.append({'field_paths': _field_path_candidates(_rd.get('name') or ''), 'target': _tgt})
    def _recommit_wa_radios():
        for _spec in _wa_radio_specs:
            try:
                page.evaluate(_RADIO_FORCE_COMMIT_IN_CONTAINER_JS, _spec)
            except Exception as _e:
                log("final-guard stability radio re-commit fail: " + repr(_e))
    for _i in range(8):
        # If the autofill is mid-parse, wait it out before trusting/redoing.
        if _parsing_up():
            page.wait_for_timeout(400)
            continue
        _last_v = _loc_now()
        _loc_str = (_last_v.get('location') or '').strip()
        _wa_now = _last_v.get('workauth') or {}
        if _wa_radio_specs and isinstance(_wa_now, dict) and _wa_now.get('checked') is False:
            _recommit_wa_radios()
            _consec_ok = 0
            page.wait_for_timeout(250)
            continue
        if _loc_str:
            _consec_ok += 1
            if _consec_ok >= 2:
                break
            page.wait_for_timeout(300)
            continue
        # Location went blank again -> re-pick via the robust combo filler.
        _consec_ok = 0
        try:
            page.evaluate(f"(args) => ({_LOCATION_COMBO_FILL_JS})(args)",
                          {'tail': _loc_tail, 'value': _loc_value})
            page.wait_for_timeout(350)
        except Exception as e:
            log(f"final-guard stability re-pick fail: {e}")
            break
    if _wa_radio_specs:
        _recommit_wa_radios()
    if isinstance(_last_v, dict) and _last_v:
        status['location_value'] = (_last_v.get('location') or '') or None
        status['location_ok'] = bool((_last_v.get('location') or '').strip())
        wa = _last_v.get('workauth') or {}
        status['workauth_checked'] = wa.get('checked') if isinstance(wa, dict) else None
    status['location_stable'] = (_consec_ok >= 2)
    # chain_p12: ADDITIVE doctrine fix as the very last pre-submit action --
    # commit a work-auth radio whose live container UUID regenerated (stale-fid
    # container miss) AND/OR answer an in-office/hybrid/relocation CHECKBOX-question
    # the static dry-run never enumerated. No-op when those fields are absent or
    # already selected. Never raises.
    try:
        _wa_value = ''
        for _rd in (plan.get('radios') or []):
            _l = (_rd.get('label') or '').lower()
            if any(k in _l for k in ('authoriz', 'authoris', 'eligib', 'legally', 'work in the u', 'right to work')):
                _wa_value = (choose_select_option((_rd.get('value') or '').strip(),
                              [o for o in (_rd.get('options') or []) if isinstance(o, str) and o.strip()],
                              _rd.get('label', '')) or (_rd.get('value') or '')).strip()
                break
        if not _wa_value:
            _wa_value = 'Can work for any employer'
        _dfix = page.evaluate(_DOCTRINE_CHOICE_FIX_JS, {'workauth_value': _wa_value})
        status['doctrine_fix'] = _dfix
        # (B) in-office/hybrid/relocation CHECKBOX-question: a synthetic JS click
        #     does NOT register in Ashby's React form state (the checkbox reads
        #     checked in the DOM but the submit POST still banks it empty). A
        #     TRUSTED Playwright label.click() DOES stick (verified Benchling 2658:
        #     stays checked across re-renders). So commit the affirmative checkbox
        #     in Python here, scoped to a required checkbox-group whose label
        #     matches in-office/relocate doctrine that has NO box checked yet.
        try:
            _io_re = __import__('re').compile(
                r'work from our|work out of our|in.?office|in person|able to work (from|hybrid)|onsite|on-site|relocat|local office|days (a|per) week|monday|tuesday|thursday|hybrid',
                __import__('re').I)
            for _c in page.query_selector_all('[data-field-path], div[class*=_fieldEntry_], fieldset'):
                _lab_el = _c.query_selector('label, legend')
                _lbl = (_lab_el.inner_text() if _lab_el else '') or ''
                if not _io_re.search(_lbl):
                    continue
                _boxes = _c.query_selector_all('input[type=checkbox]')
                if not _boxes:
                    continue
                if any(bool(_b.is_checked()) for _b in _boxes):
                    status['inoffice_checkbox'] = 'already-checked'
                    break
                _clicked = False
                for _b in _boxes:
                    _bid = _b.get_attribute('id') or ''
                    _ylab = _c.query_selector('label[for="' + _bid + '"]') if _bid else None
                    _ytxt = (_ylab.inner_text().strip().lower() if _ylab else '')
                    if _ytxt == 'yes' or _ytxt.startswith('yes'):
                        _ylab.scroll_into_view_if_needed(timeout=1500)
                        _ylab.click(timeout=2500)
                        _clicked = True
                        status['inoffice_checkbox'] = {'clicked': True, 'label': _ylab.inner_text().strip()}
                        break
                if not _clicked:
                    status['inoffice_checkbox'] = 'yes-option-not-found'
                page.wait_for_timeout(400)
                break
        except Exception as _ioe:
            log(f"final-guard inoffice-checkbox sweep fail: {_ioe}")
        if isinstance(_dfix, dict) and (
            (isinstance(_dfix.get('workauth'), dict) and _dfix['workauth'].get('checked'))
            or (isinstance(_dfix.get('inoffice'), dict) and _dfix['inoffice'].get('checked'))):
            page.wait_for_timeout(350)
            log(f"final-guard doctrine-fix committed: {_dfix}")
    except Exception as _e:
        log(f"final-guard doctrine-fix fail: {_e}")
    log(f"final-clobber-guard: settled={status['settled']} "
        f"location_ok={status['location_ok']} stable={status.get('location_stable')} "
        f"({(status['location_value'] or '')[:30]!r}) "
        f"workauth_checked={status['workauth_checked']} "
        f"reassert_wa={[r['target'] for r in status['reasserted_workauth']]}")
    return status


def scan_form_submit_success(submit_resps):
    """chain_p11c: a submit can produce TWO POSTs in a race -- an EARLY FormRender
    error (autofill clobber) then a clean FormSubmitSuccess once the reasserted
    fields win. Scan ALL captured (status, body) submit responses for a definitive
    Ashby `applicationFormResult.__typename == 'FormSubmitSuccess'`. A success
    ANYWHERE in the captured responses wins (you cannot un-submit). Returns True if
    found, else False. Pure/never-raises so it is unit-testable."""
    import json as _jsfs
    for item in (submit_resps or []):
        try:
            _bd = item[1] if isinstance(item, (list, tuple)) and len(item) > 1 else item
            if not _bd or 'FormSubmitSuccess' not in _bd:
                continue
            sd = _jsfs.loads(_bd) if str(_bd).strip().startswith('{') else {}
            mfs = ((sd.get('data') or {}).get('submitApplicationFormAction')
                or (sd.get('data') or {}).get('submitMultipleFormsAction') or {})
            afr = mfs.get('applicationFormResult') or {}
            if afr.get('__typename') == 'FormSubmitSuccess':
                return True
        except Exception:
            continue
    return False


def patch_plan_default_empty_radios(plan):
    """chain_034b: dryrun sometimes emits radio entries with value='' (e.g. Tarro
    'Were you referred by...' — the referral question). Default empty radio
    values to 'No' so the resolver picks the negative option instead of
    leaving the required field blank.
    Returns count of fields defaulted.
    """
    import re
    defaulted = 0
    for s in plan['steps']:
        if s.get('tool') != 'browser.act.evaluate':
            continue
        fn = s.get('args', {}).get('fn', '')
        m = re.search(r'const __payload = (\[.*?\]);', fn)
        if not m:
            continue
        try:
            payload = json.loads(m.group(1))
        except Exception:
            continue
        changed = False
        for entry in payload:
            if isinstance(entry, dict) and entry.get('value', None) == '' and isinstance(entry.get('alternates'), list) and not entry['alternates']:
                entry['value'] = 'No'
                entry['alternates'] = ['no', 'False']
                defaulted += 1
                changed = True
        if changed:
            new_payload_str = json.dumps(payload)
            s['args']['fn'] = fn.replace(m.group(1), new_payload_str)
    return defaulted

def run_plan(plan_path, no_submit=False, no_captcha=False):
    plan = json.load(open(plan_path))
    n_defaulted = patch_plan_default_empty_radios(plan)
    if n_defaulted:
        log(f"plan-patch: defaulted {n_defaulted} empty radio value(s) to 'No'")
    steps = plan['steps']
    slug = plan['slug']
    pdf_staged = plan['pdf_path_staged']

    # chain_036b (2026-05-30): UPLOAD-LAST mode to beat the Ashby autofill race.
    # On autofill-class tenants the "Autofill from resume" widget fires field-
    # population events on a microtask AFTER our post-upload retype, clobbering
    # Name/Email/Phone right before submit (server then reports them missing even
    # though the DOM .value is correct). The robust fix: type ALL text fields and
    # resolve radios/combos FIRST, then upload the resume LAST (just before the
    # submit click), and do NOT retype afterward. With every value already set by
    # real user keystrokes and committed to React state, the autofill widget on
    # the bottom resume input (#_systemfield_resume) does not re-parse, so there
    # is nothing left to clobber. Reorder is a no-op risk for clean tenants: their
    # forms accept the resume at the end identically.
    # Toggle off with ASHBY_UPLOAD_LAST=0 if a tenant regresses.
    upload_last_mode = os.environ.get('ASHBY_UPLOAD_LAST', '1') != '0'
    if upload_last_mode:
        up_idx = next((k for k, s in enumerate(steps)
                       if s.get('tool') == 'ashby.upload_resume_via_visible_button'), None)
        if up_idx is not None:
            # find the submit step (last step flagged final_submit, else a click step
            # whose meta marks it, else the last browser.click).
            sub_idx = None
            for k in range(len(steps) - 1, -1, -1):
                sk = steps[k]
                if sk.get('args', {}).get('meta', {}).get('final_submit'):
                    sub_idx = k; break
            if sub_idx is None:
                for k in range(len(steps) - 1, -1, -1):
                    if steps[k].get('tool') in ('browser.click', 'ashby.click_submit'):
                        sub_idx = k; break
            if sub_idx is not None and up_idx < sub_idx:
                # Insert the upload as late as possible WITHOUT moving it past the
                # captcha-solve step. The captcha token is single-use and a resume
                # upload re-renders the form (Ashby), which can invalidate a token
                # injected before it. So target = just before the captcha step if
                # one exists between here and submit; otherwise just before submit.
                cap_idx = next((k for k in range(len(steps))
                                if steps[k].get('tool') == 'ashby.maybe_solve_recaptcha_v3'
                                and k < sub_idx and k > up_idx), None)
                up_step = steps.pop(up_idx)
                if cap_idx is not None:
                    # cap_idx shifts down by 1 after the pop (pop was earlier)
                    target = cap_idx - 1
                else:
                    target = sub_idx - 1
                steps.insert(target, up_step)
                up_step.setdefault('args', {})['_upload_last'] = True
                log(f"UPLOAD-LAST: moved upload step {up_idx} -> idx {target} "
                    f"({'before captcha' if cap_idx is not None else 'before submit'})")
            else:
                log("UPLOAD-LAST: could not locate submit step; leaving plan order unchanged")
        plan['steps'] = steps

    pw = sync_playwright().start()
    browser = pw.chromium.connect_over_cdp(CDP)
    # Use existing context, fresh page
    ctx = browser.contexts[0]
    page = ctx.new_page()
    # 2026-06-03 anti-detect: optionally apply playwright-stealth to raise the
    # reCAPTCHA-v3 score (patches navigator.webdriver, chrome runtime, plugins,
    # WebGL vendor, etc). The strict-Ashby score-gate is a BOT-FINGERPRINT score,
    # not an IP wall (proven: residential IP + native token still scored low),
    # so the lever is the headless/automation fingerprint. Behind a flag.
    # Default OFF so the proven permissive-tenant path is unchanged; the strict
    # cohort opts in via JOBSEARCH_STEALTH=1 (stealth_ashby_sweep.py sets it).
    if _os.environ.get('JOBSEARCH_STEALTH', '0') == '1':
        try:
            from playwright_stealth import stealth_sync
            # 2026-06-05 strict-Ashby score-gate retest: playwright-stealth's
            # default UA override rewrites navigator.userAgent to an ANCIENT
            # Chrome/92 (2021) string, which reCAPTCHA-v3 penalizes HARD in
            # 2026. When the dedicated proxied Chrome is launched with a CURRENT
            # --user-agent CLI flag (Chrome 149), set JOBSEARCH_KEEP_UA=1 to make
            # stealth SKIP its UA patch so the realistic process-level UA wins.
            # (navigator.webdriver/plugins/chrome-runtime patches still apply.)
            if _os.environ.get('JOBSEARCH_KEEP_UA', '0') == '1':
                try:
                    from playwright_stealth import StealthConfig
                    stealth_sync(page, config=StealthConfig(
                        navigator_user_agent=False, nav_user_agent=False))
                    log('playwright-stealth applied (KEEP_UA: process UA preserved)')
                except Exception:
                    # older stealth without StealthConfig kw: re-assert UA after
                    stealth_sync(page)
                    log('playwright-stealth applied (no StealthConfig; UA may be clobbered)')
            else:
                stealth_sync(page)
                log('playwright-stealth applied to page')
        except Exception as _es:
            log(f'stealth apply failed (non-fatal): {_es}')
    # chain_035 diag: log the submit GraphQL response so we can distinguish
    # form-validation reject vs spam-flag vs application-limit.
    _submit_resps = []
    def _on_resp(resp):
        try:
            u = resp.url
            if 'graphql' in u and resp.request.method == 'POST':
                pd = resp.request.post_data or ''
                if 'SubmitApplication' in pd or 'submitApplication' in pd or 'ApplicationSubmit' in pd or 'SubmitMultipleFormsAction' in pd:
                    body = ''
                    full = ''
                    try:
                        full = resp.text()
                        body = full[:800]
                    except Exception:
                        body = '<no-body>'; full = ''
                    _submit_resps.append((resp.status, full))
                    try:
                        open('/tmp/last_submit_resp.json','w').write(resp.text())
                        import time as _t35
                        open(f'/tmp/submit_resp_{len(_submit_resps)}.json','w').write(resp.text())
                    except Exception: pass
                    log(f"SUBMIT-RESP status={resp.status} body={body[:400]}")
        except Exception:
