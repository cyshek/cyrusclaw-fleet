_SET_VALUE_JS = """(args) => {
  const {id, val} = args;
  const e = document.getElementById(id);
  if (!e) return {ok:false, reason:'no-el'};
  try { e.scrollIntoView({block:'center', behavior:'instant'}); } catch(_){}
  e.focus();
  // chain_034b: type=number inputs reject non-numeric strings
  // (Rho salary field). Extract first integer if present.
  let useVal = val;
  if (e.type === 'number') {
    const m = String(val).match(/[-+]?[\d,]*\d/);
    if (m) useVal = m[0].replace(/,/g, '');
    else useVal = '170000';  // fallback for salary-like fields
  }
  const proto = e.tagName === 'TEXTAREA' ? window.HTMLTextAreaElement.prototype : window.HTMLInputElement.prototype;
  const ns = Object.getOwnPropertyDescriptor(proto, 'value').set;
  // chain_036: force React to register the change even when the autofill left
  // the SAME string in .value but reset React's controlled state. React's
  // _valueTracker caches the last value; if we set the same value it treats it
  // as a no-op. Defeat by (a) clearing the tracker and (b) bouncing through ''
  // first so the input event reflects a genuine transition.
  try { if (e._valueTracker) e._valueTracker.setValue(''); } catch(_){}
  ns.call(e, '');
  e.dispatchEvent(new Event('input', {bubbles:true}));
  try { if (e._valueTracker) e._valueTracker.setValue(''); } catch(_){}
  ns.call(e, useVal);
  e.dispatchEvent(new Event('input', {bubbles:true}));
  e.dispatchEvent(new Event('change', {bubbles:true}));
  e.blur();
  return {ok:true, used:useVal, after:e.value, type:e.type, tag:e.tagName};
}"""

# chain_p7 (2026-06-04): RE-ASSERT-AFTER-PARSE. The dominant Ashby bank class is
# the resume-parse autofill clobbering a SINGLE already-filled field (Email /
# LinkedIn / Name) AFTER our fill, so the form fails validation on that one
# field at submit (Plaid=Email, Reducto=LinkedIn, Benchling=Name). The legacy
# repair passes only re-fill fids that appear in BOTH the eval-step `resolved`
# lists AND text_fields, and resolve the DOM element via bare getElementById on
# the recorded dom_id. That misses system fields (filled via fast-path, so not
# in any `resolved` list) and breaks when the planned fid suffix != the live DOM
# input id. This helper takes the AUTHORITATIVE text_fields map (planned values
# from personal-info.json) and force-sets EVERY non-empty field directly, using
# the same suffix-fallback resolve the filler uses, AFTER the parse has settled.
# It returns which fields it had to repair (cur != want) so the pre-submit scan
# reads the FINAL committed values.
_REASSERT_TEXT_JS = r"""(args) => {
  const {fields, force} = args;  // [{fid, val}], force?:bool
  const out = {repaired: [], ok: [], missing: [], errors: []};
  const resolve = (fid) => {
    let el = document.getElementById(fid);
    if (el) return el;
    const parts = fid.split('_');
    for (let i = 1; i < parts.length; i++) {
      const tail = parts.slice(i).join('_');
      el = document.getElementById(tail);
      if (el) return el;
      if (!tail.startsWith('_')) { el = document.getElementById('_' + tail); if (el) return el; }
    }
    const sysIdx = fid.indexOf('_systemfield_');
    if (sysIdx >= 0) { el = document.getElementById(fid.slice(sysIdx)); if (el) return el; }
    el = document.querySelector(`[name="${fid}"]`);
    return el;
  };
  const forceSet = (e, val) => {
    let useVal = val;
    if (e.type === 'number') {
      const m = String(val).match(/[-+]?[\d,]*\d/);
      useVal = m ? m[0].replace(/,/g,'') : '170000';
    }
    const proto = e.tagName === 'TEXTAREA' ? window.HTMLTextAreaElement.prototype : window.HTMLInputElement.prototype;
    const ns = Object.getOwnPropertyDescriptor(proto, 'value').set;
    try { if (e._valueTracker) e._valueTracker.setValue(''); } catch(_){}
    ns.call(e, '');
    e.dispatchEvent(new Event('input', {bubbles:true}));
    try { if (e._valueTracker) e._valueTracker.setValue(''); } catch(_){}
    ns.call(e, useVal);
    e.dispatchEvent(new Event('input', {bubbles:true}));
    e.dispatchEvent(new Event('change', {bubbles:true}));
    e.blur();
    return e.value;
  };
  for (const {fid, val} of (fields || [])) {
    if (val === '' || val == null) continue;
    try {
      const el = resolve(fid);
      if (!el) { out.missing.push(fid); continue; }
      if (el.tagName === 'INPUT' && ['radio','checkbox','file','submit','button'].includes(el.type)) continue;
      const cur = el.value;
      // chain_p10 (2026-06-06 Dash0 2757): with force=true, re-apply even when the
      // DOM .value already matches. The Ashby resume-parse autofill clobbers React's
      // CONTROLLED state to empty while leaving DOM .value intact (intl-tel Phone
      // field is the canonical victim: dom_value stays '346-...' but React/form-state
      // is ''), so the server reports "Missing entry" for a field that LOOKS filled.
      // forceSet() resets _valueTracker, forcing a genuine React transition that
      // re-commits the value into controlled/form state. The cur===val fast-skip is
      // only safe for the early (non-force) passes.
      if (cur === val && !force) { out.ok.push(fid); continue; }  // already correct
      forceSet(el, val);
      out.repaired.push({fid, was: (cur || '').slice(0,40), now: (el.value || '').slice(0,40), forced: !!force && cur === val});
    } catch (e) { out.errors.push({fid, error: String(e).slice(0,80)}); }
  }
  return out;
}"""

