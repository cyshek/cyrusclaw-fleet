    page.on('response', _on_resp)

    result = {"slug": slug, "steps": [], "ok": False, "error": None, "submit_response": None}
    captcha_token = None
    captcha_action = "submit"

    try:
        for i, s in enumerate(steps):
            tool = s.get('tool')
            args = s.get('args', {})
