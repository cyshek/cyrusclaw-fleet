_RADIO_CLICK_BY_ID_JS = """(args) => {
  // chain_035: click a real <input type=radio> by its id (label_for from the
  // resolver). Coord-clicking the label is unreliable for some tenants (Sierra)
  // -- the click lands but React onChange never fires. Click the input directly
  // and dispatch click+input+change so React controlled state updates.
  const {input_id} = args;
  if (!input_id) return {ok:false, reason:'no-id'};
  const el = document.getElementById(input_id);
  if (!el) return {ok:false, reason:'no-el', input_id};
  try { el.scrollIntoView({block:'center', behavior:'instant'}); } catch(e){}
  const lbl = document.querySelector(`label[for=\"${input_id}\"]`);
  const r = (lbl||el).getBoundingClientRect();
  const ev = {bubbles:true,cancelable:true,clientX:r.left+r.width/2,clientY:r.top+r.height/2,pointerType:'mouse',button:0,pointerId:1,isPrimary:true};
  const tgt = lbl || el;
  tgt.dispatchEvent(new PointerEvent('pointerdown', ev));
  tgt.dispatchEvent(new MouseEvent('mousedown', ev));
  tgt.dispatchEvent(new PointerEvent('pointerup', ev));
  tgt.dispatchEvent(new MouseEvent('mouseup', ev));
  tgt.dispatchEvent(new MouseEvent('click', ev));
  if (!el.checked) {
    try { el.click(); } catch(e){}
  }
  // force-set checked + fire React events as last resort
  if (!el.checked) {
    const setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'checked').set;
    try { setter.call(el, true); } catch(e){}
    el.dispatchEvent(new Event('input', {bubbles:true}));
    el.dispatchEvent(new Event('change', {bubbles:true}));
  }
  return {ok:true, checked:el.checked, input_id};
}"""

_RADIO_FORCE_COMMIT_IN_CONTAINER_JS = """(args) => {
  // chain_p11b (2026-06-08): force-commit a radio/select option INSIDE a known
  // field container (by data-field-path candidates) to its target label. Some
  // Ashby tenants ignore a plain label.click() for radios (click lands, React
  // onChange never fires) so the option reads UNCHECKED at submit and the POST
  // banks "Missing entry for required field". This locates the container, finds
  // the option whose label matches `target`, then commits via a TRUSTED pointer
  // sequence + native checked-setter + input/change events. Idempotent.
  const {field_paths, target} = args;
  const tnorm = (target || '').trim().toLowerCase();
  let cont = null;
  for (const fp of (field_paths || [])) {
    cont = document.querySelector(`[data-field-path="${fp}"]`);
    if (cont) break;
  }
  if (!cont) {
    // fallback: a fieldset/div whose label text leads with the question is hard
    // to key here; bail so caller can log no-container.
    return {ok:false, reason:'no-container'};
  }
  // Gather candidate option rows: a real radio input + its visible label text.
  const rows = [];
  cont.querySelectorAll('label').forEach(lab => {
    const t = (lab.innerText || '').trim();
    if (!t) return;
    let inp = null;
    const forId = lab.getAttribute('for');
    if (forId) inp = document.getElementById(forId);
    if (!inp) inp = lab.querySelector('input[type=radio], input[type=checkbox]');
    if (!inp) {
      // input may be a sibling within the same row container
      const row = lab.closest('div');
      if (row) inp = row.querySelector('input[type=radio], input[type=checkbox]');
    }
    rows.push({lab, t, inp});
  });
  // Choose the row matching target (exact, then contains, then startswith).
  let pick = rows.find(r => r.t.toLowerCase() === tnorm)
          || rows.find(r => r.t.toLowerCase().includes(tnorm) && tnorm.length > 2)
          || rows.find(r => tnorm.includes(r.t.toLowerCase()) && r.t.length > 2);
  if (!pick) return {ok:false, reason:'no-option-match', target, opts: rows.map(r => r.t)};
  const {lab, inp} = pick;
  const fire = (el) => {
    try { el.scrollIntoView({block:'center', behavior:'instant'}); } catch(e){}
    const r = el.getBoundingClientRect();
    const ev = {bubbles:true,cancelable:true,clientX:r.left+r.width/2,clientY:r.top+r.height/2,pointerType:'mouse',button:0,pointerId:1,isPrimary:true};
    el.dispatchEvent(new PointerEvent('pointerdown', ev));
    el.dispatchEvent(new MouseEvent('mousedown', ev));
    el.dispatchEvent(new PointerEvent('pointerup', ev));
    el.dispatchEvent(new MouseEvent('mouseup', ev));
    el.dispatchEvent(new MouseEvent('click', ev));
  };
  // 1) trusted-click the label (registers in React for most tenants)
  fire(lab);
  // 2) if we have the input, trusted-click it too + force-set checked
  if (inp) {
    if (!inp.checked) fire(inp);
    if (!inp.checked) { try { inp.click(); } catch(e){} }
    if (!inp.checked) {
      try {
        const setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'checked').set;
        setter.call(inp, true);
      } catch(e){}
      inp.dispatchEvent(new Event('input', {bubbles:true}));
      inp.dispatchEvent(new Event('change', {bubbles:true}));
    }
    return {ok:true, checked: !!inp.checked, picked: pick.t};
  }
  // No input handle: the label click is our best effort.
  return {ok:true, checked: null, picked: pick.t, note:'no-input-handle'};
}"""

_LOCATION_COMBO_FILL_JS = """async (args) => {
  // chain_035: fill a location-style typeahead combobox by its container
  // field-path tail. Used as a FALLBACK when the plan's location-resolve step
  // cannot find the input (e.g. ElevenLabs renders Location as a CUSTOM field
  // whose fid has no 'location' substring and no id/name -> only an
  // input[role=combobox] with placeholder 'Start typing...'). Types the value
  // char-by-char, waits for the listbox, clicks the best option.
  const {tail, value} = args;
  const sleep = (ms)=>new Promise(r=>setTimeout(r,ms));
  let cont = [...document.querySelectorAll('[data-field-path]')]
    .find(e => (e.getAttribute('data-field-path')||'').endsWith(tail));
  // fallback: any required combobox whose label says Location (broadened
  // 2026-06-08 for Modern Treasury ~2602: "Where will you be working from?"
  // and similar labels that have no "location" substring).
  if (!cont) {
    cont = [...document.querySelectorAll('[data-field-path]')].find(e => {
      const lbl=(e.querySelector('label')||{}).textContent||'';
      return /location|working from|will you be based|are you based|are you located|will you work from|where will you be|based out of/i.test(lbl) && e.querySelector('input[role=combobox]');
    });
  }
  if (!cont) return {ok:false, reason:'no-container'};
  const inp = cont.querySelector('input[role=combobox]') || cont.querySelector('input[type=text]');
  if (!inp) return {ok:false, reason:'no-input'};
  const setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype,'value').set;
  // chain_036: read options scoped to THIS input's listbox via aria-controls/
  // aria-owns, falling back to any visible listbox option. Prevents grabbing a
  // sibling combobox's options (the 'Wallis and Futuna' bug -> a city string
  // fed an unrelated geo list, no scoping).
  const scopedOpts = () => {
    const lbId = inp.getAttribute('aria-controls') || inp.getAttribute('aria-owns');
    let lb = lbId ? document.getElementById(lbId) : null;
    let o = lb ? [...lb.querySelectorAll('[role=\"option\"]')]
               : [...document.querySelectorAll('[role=\"listbox\"] [role=\"option\"], [role=\"option\"]')];
    return o.filter(x=>{const r=x.getBoundingClientRect();return r.width>0&&r.height>0;});
  };
  const city = value.split(',')[0].trim();
  // chain_036: Ashby geo-autocomplete chokes on 'City, ST' (comma+state).
  // Try a sequence of progressively simpler query strings.
  const tries = [city, city + ', WA', value, city + ', Washington'];
  for (const q of tries) {
    inp.focus();
    setter.call(inp, '');
    inp.dispatchEvent(new Event('input',{bubbles:true}));
    await sleep(120);
    for (const ch of q) {
      setter.call(inp, inp.value + ch);
      inp.dispatchEvent(new Event('input',{bubbles:true}));
      inp.dispatchEvent(new KeyboardEvent('keydown',{key:ch,bubbles:true}));
      await sleep(55);
    }
    // wait for options (geo lookup is async)
    let opts=[];
    for (let t=0;t<4000;t+=150){ opts=scopedOpts(); if(opts.length) break; await sleep(150); }
    if (!opts.length) continue;
    const wantC = city.toLowerCase();
    let pick = opts.find(o=>o.textContent.trim().toLowerCase()===value.toLowerCase())
            || opts.find(o=>o.textContent.trim().toLowerCase().startsWith(wantC))
            || opts.find(o=>o.textContent.trim().toLowerCase().includes(wantC));
    if (pick) {
      pick.scrollIntoView({block:'center'});
      pick.dispatchEvent(new MouseEvent('mousedown',{bubbles:true}));
      pick.dispatchEvent(new MouseEvent('mouseup',{bubbles:true}));
      pick.click();
      await sleep(250);
      return {ok:true, picked: pick.textContent.trim().slice(0,60), typed:q};
    }
  }
  // INTEGRITY GUARD: never auto-pick garbage. Report options for review.
  {
    const opts=scopedOpts();
    return {ok:false, reason:'no-exact-match', typed:value,
            options: opts.slice(0,6).map(o=>o.textContent.trim())};
  }
}"""

_CHECKBOX_ACK_JS = """(args) => {
  // Resolve a required-acknowledgement checkbox by its question UUID tail and
  // click its label. Ashby labeled-checkbox inputs have name=<labelText> (NOT a
  // uuid) and id=<entryId>_<questionUuid>-labeled-checkbox-<n>, wrapped by a
  // container <div data-field-path="<questionUuid>">. The old name-uuid resolver
  // missed them. chain_035 fix.
  const {want_name, want_text} = args;
  const uuidRe = /[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/gi;
  const uuids = (want_name||'').match(uuidRe) || [];
  const tail = uuids[uuids.length - 1];
  if (!tail) return {ok:false, reason:'no-tail'};
  let container = document.querySelector(`[data-field-path=\"${tail}\"]`);
  if (!container) {
    // fallback: any checkbox whose id contains the tail
    const cb = [...document.querySelectorAll('input[type=checkbox]')].find(c => (c.id||'').includes(tail));
    if (cb) container = cb.closest('[data-field-path]') || cb.parentElement;
  }
  if (!container) return {ok:false, reason:'no-container', tail};
  const inputs = [...container.querySelectorAll('input[type=checkbox]')];
  if (!inputs.length) return {ok:false, reason:'no-checkbox-input', tail};
  const lblText = (id) => (document.querySelector(`label[for=\"${id}\"]`)?.textContent||'').trim().toLowerCase();
  let target = inputs[0];
  if (want_text) {
    const w = want_text.trim().toLowerCase();
    target = inputs.find(i => lblText(i.id) === w)
          || inputs.find(i => lblText(i.id).startsWith(w))
          || inputs.find(i => lblText(i.id).includes(w)) || inputs[0];
  }
  if (target.checked) return {ok:true, already:true, id:target.id};
  const label = document.querySelector(`label[for=\"${target.id}\"]`) || target.closest('label') || target.parentElement;
  try { (label||target).scrollIntoView({block:'center', behavior:'instant'}); } catch(e){}
  const el = label || target;
  const r = el.getBoundingClientRect();
  const cx = r.left + r.width/2, cy = r.top + r.height/2;
  const ev = {bubbles:true,cancelable:true,clientX:cx,clientY:cy,pointerType:'mouse',button:0,pointerId:1,isPrimary:true};
  el.dispatchEvent(new PointerEvent('pointerdown', ev));
  el.dispatchEvent(new MouseEvent('mousedown', ev));
  el.dispatchEvent(new PointerEvent('pointerup', ev));
  el.dispatchEvent(new MouseEvent('mouseup', ev));
  el.dispatchEvent(new MouseEvent('click', ev));
  // also try direct .click() on the input as a belt-and-suspenders
  if (!target.checked) { try { target.click(); } catch(e){} }
  return {ok:true, checked:target.checked, id:target.id, label:(el.textContent||'').trim().slice(0,40)};
}"""

def log(msg): print(f"[runner] {msg}", file=sys.stderr, flush=True)

def _collect_text_fields(steps, upto_i):
    """Return the authoritative {fid: value} map from the plan's
    ashby.type_text_fields step (the values resolved from personal-info.json)."""
    for j in range(upto_i):
        if steps[j].get('tool') == 'ashby.type_text_fields':
            return dict(steps[j].get('args', {}).get('text_fields', {}) or {})
    return {}

def reassert_text_fields(page, text_fields, stabilize_passes=3, settle_ms=900, force=False):
    """chain_p7: re-assert EVERY authoritative text/system field after the Ashby
    resume-parse autofill settles, so a clobbered Email/LinkedIn/Name field wins
    the race. Iterates text_fields DIRECTLY (not the eval `resolved` intersection)
    and resolves the DOM input by suffix-fallback. Loops a few passes with a short
    settle between because some tenants keep re-clobbering on later microtasks;
    breaks early once a full pass repairs nothing. Returns the union of fids that
    were repaired across passes. Best-effort; never raises.
    chain_p10: pass force=True for the FINAL pre-submit pass so every field is
    re-applied through the _valueTracker reset even when DOM .value already
    matches -- defeats the autofill 'DOM-value-kept-but-React-state-emptied'
    clobber (intl-tel Phone field on Dash0 2757)."""
    fields = [{"fid": k, "val": v} for k, v in (text_fields or {}).items() if v not in ('', None)]
    if not fields:
        return []
    repaired_union = []
    seen = set()
    for p in range(max(1, stabilize_passes)):
        try:
            res = page.evaluate(_REASSERT_TEXT_JS, {"fields": fields, "force": bool(force)})
        except Exception as e:
            log(f"reassert-text pass {p+1} eval fail: {e}")
            break
        rep = res.get('repaired', []) if isinstance(res, dict) else []
        for r in rep:
            fid = r.get('fid') if isinstance(r, dict) else r
            if fid and fid not in seen:
                seen.add(fid); repaired_union.append(fid)
        miss = res.get('missing', []) if isinstance(res, dict) else []
        log(f"reassert-text pass {p+1}: repaired={len(rep)} {[ (r.get('fid') or '')[-24:] for r in rep ]} missing={len(miss)}")
        if not rep:
            break  # full pass found nothing clobbered -> stable
        if p < stabilize_passes - 1:
            try: page.wait_for_timeout(settle_ms)
            except Exception: pass
    return repaired_union


# ---------------------------------------------------------------------------
# chain_p9 (2026-06-04 ashby-batch4): CUSTOM-SELECT RE-ASSERT.
# The next dominant Ashby bank class after the text-field clobber: custom
# NON-Yes/No single-selects (Ashby ValueSelect rendered as a multi-option
# radio group OR, on some tenants, a react-select `.select__control`) whose
# resolved value is filled ONCE during the radio-resolve pass but is then
# (a) cleared by the resume-parse autofill re-render, or (b) never committed
# because the resolved value didn't textually match any option label.
# Confirmed:
#   * Cape 2800 "3 days/wk NYC office / DC office / cannot come in" select —
#     dryrun resolved value="Yes" (US-onsite doctrine answer_yes), but "Yes"
#     matches NO option label, so the radio-fill no_match'd and the field
#     stayed empty -> bank. The truthful answer is an AFFIRMATIVE office
#     option (Cyrus relocates anywhere in the US, onsite never a knockout).
#   * Helion 2712 "have you worked for Helion" 4-option select — resolved
#     value="I have not worked for Helion" matches an option, but the autofill
#     clobber clears it and the legacy yesno-verify (which only handles _yesno_
#     button widgets and bare-substring radio match) didn't re-commit reliably.
# The fix mirrors the existing chain_p7/p8 text re-assert and the yesno-verify
# radio re-click, but for arbitrary single-option selects: resolve the BEST
# option deterministically (choose_select_option), confirm the committed value,
# and re-pick it scoped to THAT field's own container/menu if it doesn't match.

_AFFIRMATIVE_HINTS = (
    "i can", "i am able", "i'm able", "i am willing", "yes", "i agree",
    "i confirm", "i acknowledge", "in office", "in-office", "in person",
    "in-person", "on-site", "onsite",
)
_NEGATIVE_HINTS = (
    "cannot", "can not", "can't", "unable", "i am not able", "not able",
    "i do not", "i don't", "none of", "no, ", "decline",
)
_PRIOR_EMPLOYER_HINTS = ("worked for", "work for", "employee of", "employed by", "current or former")
_NEVER_WORKED_HINTS = (
    "have not worked", "haven't worked", "never worked", "not worked",
    "do not work", "don't work", "i have not", "no, i have not", "none", "n/a",
)


def _norm(s):
    return (s or "").strip().lower()


def choose_select_option(want, options, label=""):
    """Pure, deterministic chooser: given the dryrun-resolved value `want` and
    the live option label list `options`, return the option string to commit
    (or None if nothing sensible matches). Mirrors the radio-fill ladder
    (exact -> startswith -> substring) then layers the truthful Ashby doctrine
    fallbacks the plain ladder misses:

      1. Exact / startswith / substring on `want` (and `want` inside option).
      2. PRIOR-EMPLOYER selects ("have you worked for X"): Cyrus has NOT worked
         for these companies, so when `want` is a negative/no answer (or the
         options are clearly a worked-here ladder) pick the honest
         "have not worked / no" option, NEVER an "I am a current/former employee"
         option.
      3. AFFIRMATIVE-ARRANGEMENT selects (onsite/hybrid/office "can you come in"
         arrangement) when `want` is affirmative (Yes / I can / willing): pick
         an affirmative office option, explicitly avoiding any "cannot/unable"
         option (US-onsite-never-a-knockout doctrine).

    Returns the chosen option label EXACTLY as it appears in `options`, or None.
    Never raises. This is the single source of truth the JS re-pick targets."""
    opts = [o for o in (options or []) if isinstance(o, str) and o.strip()]
    if not opts:
        return None
    w = _norm(want)
    lab = _norm(label)

    # ---- 1. plain ladder (matches the radio-fill behavior exactly) ----
    if w:
        for o in opts:
            if _norm(o) == w:
                return o
        for o in opts:
            if _norm(o).startswith(w):
                return o
        for o in opts:
            if w in _norm(o):
                return o
        # want may be the longer string containing an option (rare)
        for o in opts:
            on = _norm(o)
            if on and on in w:
                return o

    # ---- 2. prior-employer ladder ----
    is_prior_employer = any(h in lab for h in _PRIOR_EMPLOYER_HINTS) or any(
        h in _norm(o) for o in opts for h in ("former ", "current ") if "employee" in _norm(o)
    )
    want_negative = (w in ("no", "false", "") or any(h in w for h in _NEVER_WORKED_HINTS))
    if is_prior_employer and want_negative:
        for o in opts:
            if any(h in _norm(o) for h in _NEVER_WORKED_HINTS):
                return o
        # else fall through to affirmative/neg logic below

    # ---- 3. affirmative-arrangement ladder ----
    # Only fire when the question is actually an arrangement/onsite/availability
    # question (label or options hint at it) AND `want` is affirmative. This
    # avoids picking an arbitrary first option for an unrelated select that just
    # happened to resolve to "Yes" with no matching option.
    _ARRANGEMENT_HINTS = ("office", "onsite", "on-site", "in person", "in-person",
                          "hybrid", "remote", "days a week", "days/week", "days per week",
                          "come in", "commute", "relocat", "in the", "work arrangement",
                          "willing", "able to", "can you", "availab")
    is_arrangement = any(h in lab for h in _ARRANGEMENT_HINTS) or any(
        h in _norm(o) for o in opts for h in ("office", "onsite", "in person", "remote", "days a week", "i can work", "i cannot")
    )
    want_affirmative = (w in ("yes", "true") or any(h in w for h in ("i can", "willing", "able", "agree", "onsite", "in office", "in-office", "in person")))
    if is_arrangement and want_affirmative:
        # prefer an explicitly affirmative option that is NOT a negative one
        for hint in _AFFIRMATIVE_HINTS:
            for o in opts:
                on = _norm(o)
                if hint in on and not any(neg in on for neg in _NEGATIVE_HINTS):
                    return o
        # else the first non-negative option (avoid "cannot/none")
        for o in opts:
            if not any(neg in _norm(o) for neg in _NEGATIVE_HINTS):
                return o

    return None


_REASSERT_SELECT_JS = r"""(args) => {
  // chain_p9: re-assert ONE custom single-select to a target option label,
  // SCOPED to that field's own container (data-field-path) so we never bind to
  // a sibling control's open menu (the documented remix id-collision bug).
  // Handles two DOM shapes inside the container:
  //   (A) traditional <input type=radio> group  -> click the matching label.
  //   (B) react-select `.select__control`       -> open it, click the matching
  //       `.select__option` from THIS control's own `.select__menu`.
  // Returns {ok, shape, before, after, reason}. Never throws.
  const {field_paths, target} = args;
  const want = (target || '').trim().toLowerCase();
  if (!want) return {ok:false, reason:'no-target'};
  // locate the field container by any of the candidate field-paths
  let cont = null;
  for (const fp of (field_paths || [])) {
    cont = document.querySelector(`[data-field-path="${fp}"]`);
    if (cont) break;
  }
  if (!cont) return {ok:false, reason:'no-container', field_paths};
  const norm = (s) => (s||'').trim().toLowerCase();
  const matches = (txt) => { const t = norm(txt); return t === want || t.startsWith(want) || t.includes(want) || (t && want.includes(t)); };

  // ---- (A) radio group ----
  const radios = [...cont.querySelectorAll('input[type=radio]')];
  if (radios.length) {
    const lblText = (r) => norm((document.querySelector(`label[for="${r.id}"]`)||r.closest('label')||{}).textContent||'');
    const cur = radios.find(r => r.checked);
    const curTxt = cur ? lblText(cur) : '';
    if (cur && matches(curTxt)) return {ok:true, shape:'radio', before:curTxt, after:curTxt, already:true};
    const tgt = radios.find(r => matches(lblText(r)));
    if (!tgt) return {ok:false, shape:'radio', reason:'no-option-match', before:curTxt, options:radios.map(lblText)};
    const lbl = document.querySelector(`label[for="${tgt.id}"]`) || tgt.closest('label') || tgt;
    try { lbl.scrollIntoView({block:'center', behavior:'instant'}); } catch(e){}
    const r = lbl.getBoundingClientRect();
    const ev = {bubbles:true,cancelable:true,clientX:r.left+r.width/2,clientY:r.top+r.height/2,pointerType:'mouse',button:0,pointerId:1,isPrimary:true};
    lbl.dispatchEvent(new PointerEvent('pointerdown', ev));
    lbl.dispatchEvent(new MouseEvent('mousedown', ev));
    lbl.dispatchEvent(new PointerEvent('pointerup', ev));
    lbl.dispatchEvent(new MouseEvent('mouseup', ev));
    lbl.dispatchEvent(new MouseEvent('click', ev));
    if (!tgt.checked) { try { tgt.click(); } catch(e){} }
    if (!tgt.checked) {
      const setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype,'checked').set;
      try { setter.call(tgt, true); } catch(e){}
      tgt.dispatchEvent(new Event('input',{bubbles:true}));
      tgt.dispatchEvent(new Event('change',{bubbles:true}));
    }
    return {ok:tgt.checked, shape:'radio', before:curTxt, after:lblText(tgt)};
  }

  // ---- (B) react-select control (scoped to THIS container) ----
  const control = cont.querySelector('.select__control');
  if (control) {
    const single = cont.querySelector('.select__single-value');
    const curTxt = norm(single ? single.textContent : '');
    if (curTxt && matches(curTxt)) return {ok:true, shape:'react-select', before:curTxt, after:curTxt, already:true};
    // open the menu
    const r0 = control.getBoundingClientRect();
    const ev0 = {bubbles:true,cancelable:true,clientX:r0.left+r0.width/2,clientY:r0.top+r0.height/2,pointerType:'mouse',button:0,pointerId:1,isPrimary:true};
    control.dispatchEvent(new PointerEvent('pointerdown', ev0));
    control.dispatchEvent(new MouseEvent('mousedown', ev0));
    control.dispatchEvent(new MouseEvent('mouseup', ev0));
    control.dispatchEvent(new MouseEvent('click', ev0));
    // ANTI-COLLISION: only read options from THIS container's own menu. The
    // react-select menu is portaled in some builds; prefer the in-container
    // menu, else a menu whose controlling input id matches this container.
    let menu = cont.querySelector('.select__menu');
    if (!menu) {
      const hidden = cont.querySelector('input[id]');
      const qid = hidden ? hidden.id : null;
      const menus = [...document.querySelectorAll('.select__menu')];
      // last resort: a menu inside the same fieldEntry, never a global pick
      menu = menus.find(m => cont.contains(m)) || null;
      if (!menu && qid) {
        menu = menus.find(m => { const a = m.closest('[data-field-path]'); return a && (field_paths||[]).includes(a.getAttribute('data-field-path')); }) || null;
      }
    }
    if (!menu) return {ok:false, shape:'react-select', reason:'no-scoped-menu', before:curTxt};
    const opts = [...menu.querySelectorAll('.select__option')];
    const tgt = opts.find(o => matches(o.textContent));
    if (!tgt) return {ok:false, shape:'react-select', reason:'no-option-match', before:curTxt, options:opts.map(o=>norm(o.textContent))};
    try { tgt.scrollIntoView({block:'center', behavior:'instant'}); } catch(e){}
    const r1 = tgt.getBoundingClientRect();
    const ev1 = {bubbles:true,cancelable:true,clientX:r1.left+r1.width/2,clientY:r1.top+r1.height/2,pointerType:'mouse',button:0,pointerId:1,isPrimary:true};
    tgt.dispatchEvent(new PointerEvent('pointerdown', ev1));
    tgt.dispatchEvent(new MouseEvent('mousedown', ev1));
    tgt.dispatchEvent(new MouseEvent('mouseup', ev1));
    tgt.dispatchEvent(new MouseEvent('click', ev1));
    const after = norm((cont.querySelector('.select__single-value')||{}).textContent||'');
    return {ok:matches(after), shape:'react-select', before:curTxt, after};
  }

  return {ok:false, reason:'no-select-widget', field_paths};
}"""


def _field_path_candidates(name):
    """Mirror the filler's extractFieldPath: full fid, trailing UUID, trailing
    _systemfield_ suffix. Used to scope the JS re-pick to the right container."""
    import re as _re
    cands = [name]
    uuids = _re.findall(r'[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}', name or '')
    if uuids:
        cands.append(uuids[-1])
    si = (name or '').find('_systemfield_')
    if si >= 0:
        cands.append(name[si:])
    # chain (Helion 2712): Ashby renders the container's data-field-path as the
    # bare `question_<numericId>` suffix (NOT the UUID, NOT the full fid). The
    # plan fid is `<entryUuid>_question_<id>`, so strip the leading `<uuid>_`
    # prefix to recover the real container key. Also match a trailing
    # `question_<id>` as a belt-and-suspenders.
    qi = (name or '').find('_question_')
    if qi >= 0:
        cands.append(name[qi + 1:])  # drop leading underscore -> 'question_<id>'
    qm = _re.search(r'(question_[0-9]+)$', name or '')
    if qm:
        cands.append(qm.group(1))
    # de-dup, preserve order
    seen = set(); out = []
    for c in cands:
        if c and c not in seen:
            seen.add(c); out.append(c)
    return out


def reassert_select_fields(page, radios):
    """chain_p9: re-assert every CUSTOM single-select (a plan `radios` entry that
    is NOT a plain Yes/No) to its truthful option, scoped to that field's own
    container so we never bind to a sibling control's open menu. Resolves the
    target option deterministically via choose_select_option (affirmative-office
    / honest-prior-employer doctrine), then re-picks via _REASSERT_SELECT_JS if
    the committed value doesn't match. Yes/No radios are left to the existing
    yesno-verify block. Returns a list of dicts describing each re-pick. Never
    raises."""
    out = []
    for rd in (radios or []):
        try:
            name = rd.get('name') or ''
            want = (rd.get('value') or '').strip()
            options = [o for o in (rd.get('options') or []) if isinstance(o, str) and o.strip()]
            if not name or not options:
                continue
            # Skip plain Yes/No widgets — the yesno-verify block owns those.
            opt_set = {(_norm(o)) for o in options}
            is_yesno = opt_set <= {'yes', 'no'} and len(opt_set) <= 2
            if is_yesno:
                continue
            target = choose_select_option(want, options, rd.get('label', ''))
            if not target:
                out.append({'name': name[-24:], 'want': want, 'picked': None, 'reason': 'no-choosable-option', 'options': options})
                continue
            res = page.evaluate(_REASSERT_SELECT_JS, {
                'field_paths': _field_path_candidates(name),
                'target': target,
            })
            entry = {'name': name[-24:], 'want': want, 'target': target}
            if isinstance(res, dict):
                entry.update({'ok': res.get('ok'), 'shape': res.get('shape'),
                              'already': res.get('already', False),
                              'before': res.get('before'), 'after': res.get('after'),
                              'reason': res.get('reason')})
            out.append(entry)
        except Exception as e:
            log(f"reassert-select fail for {(rd.get('name') or '')[-20:]}: {e}")
    committed = [e for e in out if e.get('ok') and not e.get('already')]
    log(f"reassert-select: {len(out)} custom-select(s) checked, {len(committed)} re-committed")
    return out


def wait_autofill_settle(page, max_ms=12000, quiet_ms=1500):
    """Block until the Ashby resume-autofill parse finishes and the form DOM is
    quiescent. The autofill widget shows a "Parsing your resume. Autofilling key
    fields..." banner while it re-renders (and clobbers already-set fields). On
    pathological tenants (Snowflake) the re-render fires LATE, racing field fills.
    Calling this right after the resume upload — BEFORE any radio/text fill — lets
    the autofill finish first so subsequent fills stick. Returns True if it saw a
    clean settle, False on timeout (caller proceeds anyway). Best-effort; never
    raises."""
    import time as _t
    _deadline = _t.time() + (max_ms / 1000.0)
    _PARSING_RE = "parsing your resume|autofilling key fields|analyzing your resume"
    _last_sig = None
    _quiet_since = None
    while _t.time() < _deadline:
        try:
            _busy = page.evaluate(
                "(re)=>{const t=(document.body.innerText||'').toLowerCase();"
                "return new RegExp(re).test(t);}", _PARSING_RE)
        except Exception:
            _busy = False
        try:
            # DOM signature: count of inputs + their concatenated values length.
            _sig = page.evaluate(
                "()=>{const xs=[...document.querySelectorAll('input,textarea,select')];"
                "return xs.length+':'+xs.reduce((a,e)=>a+(String(e.value||'').length),0);}")
        except Exception:
            _sig = None
        _now = _t.time()
        if not _busy and _sig == _last_sig and _sig is not None:
            if _quiet_since is None:
                _quiet_since = _now
            elif (_now - _quiet_since) * 1000.0 >= quiet_ms:
                return True
        else:
            _quiet_since = None
            _last_sig = _sig
        page.wait_for_timeout(250)
    return False


# chain_p11 (2026-06-08, Rogo 2475/2901-2904): the resume-autofill widget
# RE-EMPTIES the Location typeahead + the work-auth radio AT SUBMIT -- it fires
# its LAST DOM mutation AFTER our earlier force-reassert wins, so by the time the
# submit POST serializes the form those two fields are blank again and Ashby
# FormRender returns "Missing entry" for Location + work-auth. The earlier
# upload-last/chain_p7/p8 reasserts run too soon to beat this final clobber.
#
# FIX = deterministic settle-THEN-reassert as the VERY LAST action before submit:
#   1. wait_autofill_settle() so the autofill has emitted its last mutation (NOT a
#      fixed sleep -- it returns as soon as the DOM signature goes quiet, capped).
#   2. re-run the idempotent location_typeahead_v2 step (refills the Location combo).
#   3. re-assert the work-auth radio(s) via a TRUSTED label click (registers in
#      React even if .checked already reads true).
#   4. VERIFY in the same tick that Location input is non-empty AND the work-auth
#      radio is checked. Returns a status dict; caller proceeds to submit and logs.
# Because this is gated on the settle signal it runs only once the autofill can no
# longer fire, so the reassert is the last write the serializer sees.
_VERIFY_LOC_WORKAUTH_JS = r"""() => {
  const out = {location: null, workauth: null};
  // Location: find a required combobox whose label mentions Location, report its value.
  const conts = [...document.querySelectorAll('[data-field-path], [class*=_fieldEntry_], fieldset')];
  for (const c of conts) {
