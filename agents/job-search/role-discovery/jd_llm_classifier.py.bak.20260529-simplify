def backup_db_once() -> Optional[Path]:
    stamp = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M")
    bak = DB.with_suffix(f".db.bak.{stamp}-llm-run")
    if not bak.exists():
        shutil.copy2(DB, bak)
        return bak
    return None


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--limit", type=int, default=None)
    ap.add_argument("--role-id", type=int, default=None)
    ap.add_argument("--dry-run", action="store_true")
    ap.add_argument("--force", action="store_true",
                    help="re-classify even if llm_classified_at is set")
    ap.add_argument("--sleep", type=float, default=0.3,
                    help="seconds between model calls (rate-limit politeness)")
    args = ap.parse_args()

    if not DB.exists():
        print(f"ERR tracker.db missing: {DB}", file=sys.stderr)
        return 2

    con = sqlite3.connect(DB)
    # Confirm migration ran
    cols = {r[1] for r in con.execute("PRAGMA table_info(roles)").fetchall()}
    if "llm_classified_at" not in cols:
        print("ERR run migrate_llm_classifier_columns.py first", file=sys.stderr)
        return 2

    rows = fetch_target_rows(con, limit=args.limit, role_id=args.role_id, force=args.force)
    print(f"[llm-classifier] {len(rows)} rows to process (dry_run={args.dry_run})")
    if not rows:
        print("[llm-classifier] nothing to do.")
        return 0

    if not args.dry_run:
        bak = backup_db_once()
        if bak:
            print(f"[llm-classifier] backed up DB -> {bak.name}")

    classified = 0
    flipped = 0
    errors: list[dict] = []
    t0 = time.time()

    for i, row in enumerate(rows, 1):
        rid = row["id"]
        url = row["jd_url"] or row["app_url"]
        company = row["company"] or ""
        title = row["role"] or ""
        try:
            ats, jd = get_cached_jd(row["source_key"], url)
            jd_trimmed = jd[:JD_MAX_CHARS]
            # Build YOE-mention candidates for LLM grounding
            yoe_mentions = extract_yoe_candidate_mentions(jd_trimmed)
            if yoe_mentions:
                yoe_block = "\n".join(f"- {s}" for s in yoe_mentions)
            else:
                yoe_block = "(no year/yrs mentions found in JD)"
            prompt = PROMPT_TEMPLATE.format(
                title=title[:200], company=company[:100], jd=jd_trimmed,
                yoe_candidates=yoe_block,
            )
            parsed, _env = call_model(prompt)
            cls = normalize_classification(parsed)
        except subprocess.TimeoutExpired as e:
            errors.append({
                "id": rid, "company": company, "title": title,
                "stage": "model", "error": "timeout",
            })
            print(f"  [{i}/{len(rows)}] id={rid} ERR timeout")
            continue
        except Exception as e:
            errors.append({
                "id": rid, "company": company, "title": title,
                "url": url, "stage": "fetch_or_model",
                "error": str(e)[:500],
            })
            print(f"  [{i}/{len(rows)}] id={rid} ERR {type(e).__name__}: {str(e)[:120]}")
            continue

        if args.dry_run:
            flip = maybe_skip(con, row, cls, jd, dry_run=True)
            tag = f"[SKIP {'+'.join(flip['new_flags'])}]" if flip else ""
            print(f"  [{i}/{len(rows)}] id={rid} {company[:20]:20s} | "
                  f"yoe={cls['yoe_required']} mgr={cls['is_people_manager']} "
                  f"sen={cls['seniority']} fit={cls['fit_score']} {tag}")
        else:
            write_classification(con, rid, cls)
            flip = maybe_skip(con, row, cls, jd, dry_run=False)
            tag = f" [FLIPPED→skip {'+'.join(flip['new_flags'])}]" if flip else ""
            if flip:
                flipped += 1
            con.commit()
            print(f"  [{i}/{len(rows)}] id={rid} {company[:20]:20s} | "
                  f"yoe={cls['yoe_required']} mgr={cls['is_people_manager']} "
                  f"sen={cls['seniority']} fit={cls['fit_score']}{tag}")
        classified += 1
        if args.sleep > 0:
            time.sleep(args.sleep)

    if errors:
        stamp = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")
        err_path = ERR_DIR / f"_llm-classifier-errors-{stamp}.json"
        ERR_DIR.mkdir(exist_ok=True)
        err_path.write_text(json.dumps(errors, indent=2))
        print(f"[llm-classifier] wrote {len(errors)} errors -> {err_path}")

    dt = time.time() - t0
    print(f"[llm-classifier] DONE classified={classified} flipped_to_skip={flipped} "
          f"errors={len(errors)} elapsed={dt:.0f}s")
    # One-line summary for cron parsing:
    print(f"LLM classifier: {classified} classified, {flipped} flagged as overreach, {len(errors)} errors.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
