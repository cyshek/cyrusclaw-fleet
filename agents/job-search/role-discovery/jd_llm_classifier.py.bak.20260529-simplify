    r"\b(?:" + "|".join(re.escape(c) for c in NON_US_CITIES) + r")\b", re.I
)
_NON_US_COUNTRY_RE = re.compile(
    r"\b(?:" + "|".join(re.escape(c) for c in NON_US_COUNTRIES) + r")\b", re.I
)


def _has_us_signal(text: str) -> bool:
    return any(rx.search(text) for rx in US_ALLOW_PATTERNS)


def detect_non_us_location(jd: Optional[str], location_field: Optional[str]) -> Optional[str]:
    """Return a short reason string if the role is clearly non-US, else None.

    Conservative: requires a strong exclusive signal OR a non-US city/country
    in the location field with no offsetting US signal in either field.
    """
    loc = (location_field or "").strip()
    # Only scan the first ~3000 chars of JD for location signals (header/intro
    # is where they live; deep body talk about "the London office" shouldn't
    # trigger a skip).
    jd_head = (jd or "")[:3000]

    combined_for_us = f"{loc}\n{jd_head}"
    us_signal = _has_us_signal(combined_for_us)

    # Strong exclusive non-US patterns trump everything.
    for rx in NON_US_EXCLUSIVE_PATTERNS:
        m = rx.search(loc) or rx.search(jd_head)
        if m:
            return f"non-us:{m.group(0).strip()[:40]}"

    # Location field non-US city/country wins if no offsetting US signal in loc.
    if loc:
        loc_has_us = _has_us_signal(loc)
        if not loc_has_us:
            m = _NON_US_CITY_RE.search(loc) or _NON_US_COUNTRY_RE.search(loc)
            if m:
                return f"non-us-loc:{m.group(0).strip()[:40]}"

    # If JD opens with a non-US city/country AND nothing US appears anywhere,
    # treat as non-US. This is the conservative fallback.
    if not us_signal and jd_head:
        m = _NON_US_CITY_RE.search(jd_head) or _NON_US_COUNTRY_RE.search(jd_head)
        if m:
            return f"non-us-jd:{m.group(0).strip()[:40]}"

    return None


def _merge_flag(existing_flags: Optional[str], new_flag: str) -> str:
    """Add new_flag to a flags string, preserving order and de-duping."""
    existing = (existing_flags or "").strip()
    parts = [f for f in re.split(r"[;,\s]+", existing) if f]
    if new_flag not in parts:
        parts.append(new_flag)
    return ";".join(parts)


def _merge_flags(existing_flags: Optional[str], new_flags: list[str]) -> str:
    out = existing_flags
    for f in new_flags:
        out = _merge_flag(out, f)
    return out or ""


def maybe_skip(con: sqlite3.Connection, row: sqlite3.Row, cls: dict,
               jd_text: Optional[str], *, dry_run: bool) -> Optional[dict]:
    """Apply DETERMINISTIC skip gates. Returns dict describing the flip, or None.

    Gates (any match -> skip):
      1. Title-keyword blocklist -> 'senior-title'
      2. JD-stated YOE >= YOE_THRESHOLD -> 'yoe-threshold'
      3. LLM is_people_manager == true -> 'people-mgr'
      4. LLM seniority in {director+, manager} -> 'senior-llm'
      5. Non-US location signal -> 'non-us'

    fit_score is INTENTIONALLY NOT a skip gate (policy 2026-05-25).
    """
    if row["applied_by"]:
        return None  # never touch applied rows
    if row["status"] and row["status"] != "":
        return None  # already has a status (skip, etc.) — leave alone

    new_flags: list[str] = []
    reasons: list[str] = []
    jd_yoe: Optional[int] = None

    # Gate 1: title-keyword blocklist
    title_kw = extract_title_skip(row["role"])
    if title_kw:
        new_flags.append("senior-title")
        reasons.append(f"title:{title_kw}")

    # Gate 2: YOE — trust the LLM's grounded yoe_required exclusively.
    # The LLM sees pre-extracted candidate mentions and is instructed to ignore
    # company-age/product-metric/team-tenure numbers and to take MINIMUM when
    # a JD lists a range. If LLM returns null, treat as "no firm requirement"
    # and don't skip on YOE. Regex extraction is kept only for visibility/
    # backfill (see write side below), not as a skip gate.
    llm_yoe = cls.get("yoe_required")
    jd_yoe = llm_yoe  # for return record + flip log
    if llm_yoe is not None and llm_yoe >= YOE_THRESHOLD:
        new_flags.append("yoe-threshold")
        reasons.append(f"llm-yoe:{llm_yoe}")

    # Gate 3: people-manager (LLM)
    if cls.get("is_people_manager"):
        new_flags.append("people-mgr")
        reasons.append("llm:people-mgr")

    # Gate 4: senior seniority (LLM)
    if cls.get("seniority") in SKIP_SENIORITY:
        new_flags.append("senior-llm")
        reasons.append(f"llm-seniority:{cls['seniority']}")

    # Gate 5: non-US location
    try:
        loc_field = row["loc"]
    except (IndexError, KeyError):
        loc_field = None
    non_us = detect_non_us_location(jd_text, loc_field)
    if non_us:
        new_flags.append("non-us")
        reasons.append(non_us)

    if not new_flags:
        return None

    flip = {
        "id": row["id"],
        "company": row["company"],
        "role": row["role"],
        "new_flags": new_flags,
        "reasons": reasons,
        "jd_yoe": jd_yoe,
    }
    if dry_run:
        return flip

    merged = _merge_flags(row["flags"], new_flags)
    # If we extracted a stronger JD YOE than the LLM's, store it for visibility.
    if jd_yoe is not None:
        existing_llm_yoe = cls.get("yoe_required")
        if existing_llm_yoe is None or jd_yoe > existing_llm_yoe:
            con.execute(
                "UPDATE roles SET llm_yoe_required = ? WHERE id = ?",
                (jd_yoe, row["id"]),
            )
    con.execute(
        "UPDATE roles SET status = 'skip', flags = ? WHERE id = ?",
        (merged, row["id"]),
    )
    return flip


def write_classification(con: sqlite3.Connection, role_id: int, cls: dict) -> None:
    con.execute(
        "UPDATE roles SET "
        "llm_classified_at = ?, llm_yoe_required = ?, llm_is_people_manager = ?, "
        "llm_seniority = ?, llm_fit_score = ?, llm_reason = ? "
        "WHERE id = ?",
        (
            datetime.now(timezone.utc).isoformat(timespec="seconds"),
            cls["yoe_required"],
            1 if cls["is_people_manager"] else 0,
            cls["seniority"],
            cls["fit_score"],
            cls["reason"],
            role_id,
        ),
    )


