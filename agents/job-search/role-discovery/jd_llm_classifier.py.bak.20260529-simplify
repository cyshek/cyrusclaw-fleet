def fetch_target_rows(con: sqlite3.Connection, *, limit: Optional[int],
                      role_id: Optional[int], force: bool) -> list[sqlite3.Row]:
    con.row_factory = sqlite3.Row
    where = []
    params: list = []
    if role_id is not None:
        where.append("id = ?")
        params.append(role_id)
    else:
        # Default to open, unapplied, unclassified
        where.append("(status = '' OR status IS NULL)")
        where.append("applied_by IS NULL")
        if not force:
            where.append("llm_classified_at IS NULL")
    sql = (
        "SELECT id, source_key, company, role, loc, app_url, jd_url, status, flags, applied_by "
        "FROM roles WHERE " + " AND ".join(where) + " ORDER BY id"
    )
    if limit:
        sql += f" LIMIT {int(limit)}"
    return con.execute(sql, params).fetchall()


SKIP_SENIORITY = {"director+", "manager"}
YOE_THRESHOLD = 4  # JD-stated minimum YOE >= this -> deterministic skip

# --- Deterministic gate 1: title-keyword blocklist --------------------------
# Word-boundary, case-insensitive. Each pattern is a self-contained regex
# fragment with a single capture group naming the matched keyword.
# Notes per Cyrus 2026-05-25:
#   - 'lead' is intentionally included even though it false-positives on
#     "Lead Generation" / "Tech Lead" / "Lead Engineer" — that's the desired
#     behavior (no 'lead' titles).
#   - 'manager' / 'mgr' are blanket-blocked; 'people-manager keep current'
#     check from the LLM remains as a secondary gate.
#   - 'sr' must be matched as 'sr' or 'sr.' but NOT as a random 2-letter word
#     embedded in unrelated context; word-boundary handles that.
#   - 'staff' and 'staff+' both blocked.
#   - 'group' false-positives on team-name suffixes (e.g. "Vision Products
#     Group"). To minimize that we require 'group' to appear before a word
#     rather than at end-of-string (handled via lookahead).
#   - 'partner' false-positives on "Partner Solutions Architect" (channel
#     role, not seniority). Same lookahead trick: must be followed by another
#     word AND not be the SA/SE channel pattern.
# --- Title blocklist with target-role carve-out (Cyrus 2026-05-25 PM) ----
#
# Two layers:
#  (A) HARD blocklist keywords — if title contains any of these (word-bounded,
#      case-insensitive), SKIP unconditionally regardless of target-role match.
#      These signal seniority or non-target seniority track.
#  (B) SOFT 'manager' keyword — SKIP only if title does NOT also contain one
#      of the ALLOWED target-role substrings (PM / TPM / EPM / PgM family).
#      This is the carve-out so "Product Manager, GTM" KEEPS while
#      "Engineering Manager" SKIPS.
#
# Order in HARD list matters for the reported keyword name (specific first,
# e.g. 'chief' before 'staff' so "Chief of Staff" reports as 'chief').
HARD_BLOCKLIST = [
    ("chief",         r"\bchief\b"),
    ("distinguished", r"\bdistinguished\b"),
    ("fellow",        r"\bfellow\b"),
    ("head of",       r"\bhead\s+of\b"),
    ("principal",     r"\bprincipal\b"),
    ("director",      r"\bdirector\b"),
    ("svp",           r"\bsvp\b"),
    ("evp",           r"\bevp\b"),
    ("vp",            r"\bvp\b"),
    ("senior",        r"\bsenior\b"),
    ("sr",            r"\bsr\.?\b"),
    ("staff",         r"\bstaff\+?\b"),
    ("lead",          r"\blead\b"),
    ("mgr",           r"\bmgr\b"),
]
_HARD_RE = [(k, re.compile(p, re.I)) for k, p in HARD_BLOCKLIST]

# Positional senior-signal: 'group' as a prefix to a PM/PgM token signals
# Group PM tier (senior IC). 'partner' as prefix to SA/SE/PM is a CHANNEL role
# (partner ecosystem), NOT seniority — those keep and let YOE decide.
# Per Cyrus 2026-05-25.
#   "Group Product Manager" -> skip
#   "Group PM" -> skip
#   "Partner Solutions Architect" -> keep (channel role, not seniority)
#   "Partner PM" -> keep (channel role)
#   "EPM - Vision Products Group" -> keep (group is suffix)
#   "PM, Group 5 Mission Autonomy" -> keep (group describes product)
_POSITIONAL_PREFIX_RE = re.compile(
    r"\bgroup\s+"
    r"(?:product|program|project|technical\s+program|engineering\s+program)\s+"
    r"manager\b",
    re.I,
)
_POSITIONAL_ABBREV_RE = re.compile(
    r"\bgroup\s+(?:PM|TPM|EPM|PgM|APM|TPgM)\b",
    re.I,
)

# Soft 'manager' — word-boundary on its own; carve-out applies below.
_MANAGER_RE = re.compile(r"\bmanager\b", re.I)

# Target-role allowlist (substrings; case-insensitive). If title contains any
# of these AND the only seniority signal was 'manager', KEEP.
TARGET_ROLE_SUBSTRINGS = [
    "product manager",
    "program manager",
    "project manager",
    "technical program manager",
    "engineering program manager",
    "product marketing manager",   # IC marketing PM; per Cyrus, err on keep
    "solutions engineer",
    "solution engineer",
    "sales engineer",
    "solutions architect",
    "solution architect",
    "forward deployed engineer",
    "customer engineer",
    "software engineer",
    "product engineer",
]


# Target-role abbreviations (whole-word regex). Cyrus 2026-05-25: PM/TPM/SE etc.
# must register as target roles even when title doesn't spell them out.
_TARGET_ROLE_ABBREV_RE = re.compile(
    r"\b(?:PM|TPM|EPM|PgM|SE|SA|FDE|APM|TPgM)\b"
)


def title_has_target_role(title: str) -> bool:
    if not title:
        return False
    t = title.lower()
    if any(sub in t for sub in TARGET_ROLE_SUBSTRINGS):
        return True
    # Abbreviation pass is case-sensitive against the original title; PM/TPM/SE
    # etc. are conventionally uppercase, so we don't want to match 'pm' in
    # 'employment' or 'se' in 'design'.
    if _TARGET_ROLE_ABBREV_RE.search(title):
        return True
    return False


def extract_title_skip(title: Optional[str]) -> Optional[str]:
    """Return matched skip-keyword, or None if title should KEEP.

    Layered logic:
      1. HARD blocklist keyword present -> SKIP.
      2. Positional 'group X manager/engineer/architect' or 'partner X ...'
         -> SKIP as 'group'/'partner' (the seniority-prefix case).
      3. 'manager' present AND no target-role substring -> SKIP as 'manager'.
      4. Otherwise KEEP.
    """
    if not title:
        return None
    for kw, rx in _HARD_RE:
        if rx.search(title):
            return kw
    m = _POSITIONAL_PREFIX_RE.search(title)
    if m:
        return "group"
    m = _POSITIONAL_ABBREV_RE.search(title)
    if m:
        return "group"
    if _MANAGER_RE.search(title) and not title_has_target_role(title):
        return "manager"
    return None


# --- Deterministic gate 2: JD-stated YOE >= threshold -----------------------
_YOE_PATTERNS = [
    # SIMPLIFIED 2026-05-25 (Cyrus): just find "N years ... experience" within
    # a window. Don't enumerate adjectives (overall/relevant/professional/etc.)
    # Take MAX across all matches.
    #   "5+ years of relevant experience" -> 5
    #   "4 years overall experience" -> 4
    #   "3+ years of hands-on cloud experience" -> 3
    #   "Minimum 5 yrs experience in..." -> 5
    re.compile(
        r"\b(\d{1,2})\+?\s*(?:years?|yrs?)\b[^.\n\r]{0,80}?\bexperience\b",
        re.I,
    ),
    # "X+ years" inside a bracketed range "3-5 years" / "4 to 7 yrs" — take upper
    re.compile(
        r"\b(\d{1,2})\s*(?:-|–|to)\s*(\d{1,2})\+?\s*(?:years?|yrs?)\b",
        re.I,
    ),
    # "YOE: 5" / "YOE = 6"
    re.compile(r"\bYOE\s*[:=>]?\s*(\d{1,2})\b", re.I),
    # "minimum/at least/requires N+ years" — belt-and-suspenders for the
    # case where 'experience' doesn't follow within 80 chars
    re.compile(
        r"\b(?:minimum|at\s+least|requires?|require)\s+(?:of\s+)?(\d{1,2})\+?\s*(?:years?|yrs?)\b",
        re.I,
    ),
]


def extract_yoe_from_jd_text(jd: Optional[str]) -> Optional[int]:
    """Scan JD body for YOE statements, return MAX integer or None.

    Numbers > 25 are ignored as junk (e.g. "25 years of innovation", phone
    numbers, dates). The 3-5 year range pattern returns the upper bound.
    """
    if not jd:
        return None
    values: list[int] = []
    for rx in _YOE_PATTERNS:
        for m in rx.finditer(jd):
            groups = [g for g in m.groups() if g]
            for g in groups:
                try:
                    n = int(g)
                except (TypeError, ValueError):
                    continue
                if 0 < n < 25:
                    values.append(n)
    if not values:
        return None
    return max(values)


# --- LLM-grounded YOE: extract all "<N> years" mentions with their local
# context, hand them to the LLM, and let the LLM say which (if any) is the
# actual candidate-experience requirement. Avoids the regex false-positive
# on company-age/product-metric/team-tenure numbers.
_YEARS_MENTION_RE = re.compile(
    r"\b(\d{1,2})\+?\s*(?:-|–|to)?\s*\d{0,2}\+?\s*(?:years?|yrs?)\b",
    re.I,
)


def extract_yoe_candidate_mentions(jd: Optional[str], *, window: int = 120,
                                    max_mentions: int = 20) -> list[str]:
    """Find every "<N> years/yrs" mention in the JD with surrounding context.

    Returns a list of trimmed snippets like:
      ["... requires 5+ years of relevant experience in distributed systems ...",
       "... company was founded 3 years ago by ex-Google engineers ..."]

    Each snippet has up to `window` chars on either side of the matched
    "<N> years" phrase, with linebreaks normalized. The LLM uses these to
    decide which (if any) is a candidate-experience requirement.
    """
    if not jd:
        return []
    out: list[str] = []
    seen: set[str] = set()
    for m in _YEARS_MENTION_RE.finditer(jd):
        # Skip junk values
        try:
            n = int(m.group(1))
        except Exception:
            continue
        if not (0 < n < 25):
            continue
        start = max(0, m.start() - window)
        end = min(len(jd), m.end() + window)
        snip = jd[start:end].strip()
        snip = re.sub(r"\s+", " ", snip)
        # Mark prefix/suffix ellipsis if truncated
        if start > 0:
            snip = "… " + snip
        if end < len(jd):
            snip = snip + " …"
        if snip in seen:
            continue
        seen.add(snip)
        out.append(snip)
        if len(out) >= max_mentions:
            break
    return out


