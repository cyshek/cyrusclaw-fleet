"""Tests for the 2026-06-08 overnight Ashby field-gap LABEL_RULES + the new
`english_comfort_high` resolver.

All TRUTHFUL doctrine: US-onsite / willing-to-work-in-<city>-office,
US-travel, company-offsite travel ack are NEVER knockouts for Cyrus; he is a
native English speaker so the English-comfort scale resolves to the highest
tier. The "996" (72hr/week schedule) question is intentionally NOT given a
rule and must stay unresolved.
"""
import os
import sys

sys.path.insert(0, os.path.dirname(__file__))
import ashby_dryrun as a  # noqa: E402

gh = a.gh

YESNO = {"values": [{"label": "Yes"}, {"label": "No"}]}


# ---------- in-person / willing-to-work-in-<city>-office -> answer_yes ----------

IN_PERSON_LABELS = [
    "Are you willing to work in our San Francisco office?",
    "Are you willing to work in the office 5 days a week?",
    "This is an in-person role based in San Francisco. Can you commit?",
    "This is an in-person role in San Francisco — are you comfortable?",
]


def test_in_person_office_routes_to_yes():
    for lbl in IN_PERSON_LABELS:
        key = gh.find_resolver(lbl)
        assert key in ("answer_yes", "location_ack", "ack_in_office",
                       "us_based_confirm"), f"{lbl!r} -> {key!r}"
        status, val, _ = gh.RESOLVERS[key]({}, dict(YESNO, _label_for_resolver=lbl))
        assert status == "ok" and val == "Yes", f"{lbl!r} -> {val!r}"


# ---------- travel throughout the US -> answer_yes ----------

US_TRAVEL_LABELS = [
    "Are you able to travel throughout the United States as needed?",
    "Are you willing to travel throughout the US for this role?",
    "This role requires you to travel domestically. Can you?",
]


def test_us_travel_routes_to_yes():
    for lbl in US_TRAVEL_LABELS:
        key = gh.find_resolver(lbl)
        assert key == "answer_yes", f"{lbl!r} -> {key!r} (expected answer_yes)"
        status, val, _ = gh.RESOLVERS[key]({}, dict(YESNO, _label_for_resolver=lbl))
        assert status == "ok" and val == "Yes"


# ---------- twice-yearly / company-offsite travel ack -> answer_yes ----------

OFFSITE_LABELS = [
    "This role requires twice-yearly travel for company offsites. Are you able to commit?",
    "Are you comfortable with travel for company offsites a few times a year?",
    "We have quarterly offsites — can you attend?",
]


def test_offsite_travel_routes_to_yes():
    for lbl in OFFSITE_LABELS:
        key = gh.find_resolver(lbl)
        assert key == "answer_yes", f"{lbl!r} -> {key!r} (expected answer_yes)"
        status, val, _ = gh.RESOLVERS[key]({}, dict(YESNO, _label_for_resolver=lbl))
        assert status == "ok" and val == "Yes"


# ---------- English-proficiency comfort scale -> highest tier ----------

def test_english_comfort_routes_to_english_resolver():
    for lbl in [
        "Are you comfortable reading, writing and speaking in English?",
        "Please rate your proficiency in English.",
        "What is your English proficiency level?",
    ]:
        key = gh.find_resolver(lbl)
        assert key == "english_comfort_high", f"{lbl!r} -> {key!r}"


def test_english_comfort_yesno_picks_yes():
    f = dict(YESNO, _label_for_resolver="comfortable writing and speaking in english?")
    status, val, _ = gh.RESOLVERS["english_comfort_high"]({}, f)
    assert status == "ok" and val == "Yes"


def test_english_comfort_scale_picks_highest_tier():
    # Native should win over Fluent/Conversational/Basic.
    f = {
        "values": [
            {"label": "Basic"},
            {"label": "Conversational"},
            {"label": "Fluent"},
            {"label": "Native or bilingual"},
        ],
        "_label_for_resolver": "Select your English proficiency",
    }
    status, val, src = gh.RESOLVERS["english_comfort_high"]({}, f)
    assert status == "ok"
    assert val == "Native or bilingual", f"got {val!r} ({src})"


def test_english_comfort_scale_falls_back_to_last_option():
    # No native/fluent keyword -> ascending scale, last is highest.
    f = {
        "values": [{"label": "Level 1"}, {"label": "Level 2"}, {"label": "Level 3"}],
        "_label_for_resolver": "English comfort",
    }
    status, val, _ = gh.RESOLVERS["english_comfort_high"]({}, f)
    assert status == "ok" and val == "Level 3"


def test_english_comfort_free_text_affirmative():
    f = {"_label_for_resolver": "Describe your comfort writing in English"}
    status, val, _ = gh.RESOLVERS["english_comfort_high"]({}, f)
    assert status == "ok" and val == "Yes"


# ---------- 996 question MUST stay unresolved (flag-for-Cyrus) ----------

def test_996_question_has_no_rule():
    # Lance 2594/2595: "Are you willing to work 996?" (9-9, 6 days = ~72hr/wk).
    # This is a real schedule decision for Cyrus, NOT an onsite/travel ack.
    # It must NOT silently resolve to Yes.
    key = gh.find_resolver("Are you willing to work 996?")
    assert key != "answer_yes", "996 must not auto-resolve to Yes"
    # Either no resolver, or it routes somewhere that won't auto-affirm a
    # 72hr/week schedule. The safe contract: not answer_yes.
    assert key in (None, "optional_blank") or key is None or key != "answer_yes"


if __name__ == "__main__":
    import pytest
    raise SystemExit(pytest.main([__file__, "-q"]))
