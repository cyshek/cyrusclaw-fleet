[net-req-body-FULL] {"job_application":{"first_name":"Cyrus","last_name":"Shekari","email":"cyshekari@gmail.com","answers_attributes":{"8481035006":{"question_id":"8481035006","priority":0,"boolean_value":0},"8481036006":{"question_id":"8481036006","priority":1,"boolean_value":1},"8481037006":{"question_id":"8481037006","priority":2,"boolean_value":1},"8481038006":{"question_id":"8481038006","priority":3,"boolean_value":0},"8481039006":{"question_id":"8481039006","priority":4,"boolean_value":1},"8485102006":{"question_id":"8485102006","priority":5,"text_value":"My background is not carrier-side wireless, but a meaningful portion of my product work maps directly to the enterprise mobility and managed connectivity space MetTel operates in. At Microsoft, I led 0-to-1 development of an internal Resilience Automation Platform, authoring PRDs and managing cross-functional dependencies across BSS/OSS systems and partner engineering teams - the same integration complexity you see in carrier and managed mobility environments. I also served as bridge lead for a sovereign-cloud network isolation test tied to a $1.5B+ enterprise contract, coordinating across partner and internal teams under executive visibility. That work required the same carrier-agnostic orchestration thinking the Wireless Solutions role calls for.\n\nBeyond that, I built and maintained an innovation-style backlog for resilience initiatives - scoring and prioritizing hypotheses against business value and feasibility, conducting voice-of-customer interviews to surface unmet needs, and converting field insights into structured product hypotheses. That process mirrors exactly how the JD describes building MetTel's wireless innovation pipeline. I've also defined pricing models and packaging context at Pro Painters, sized opportunity via Power BI dashboards tracking operational gaps across 140+ teams, and built Sales enablement materials that equipped the field to position new offerings.\n\nSo no, I haven't managed a carrier relationship with Verizon or AT&T directly. What I bring is a strong 0-to-1 product track record, fluency in enterprise infrastructure dependencies, and a commercial instinct built across multiple go-to-market motions. I'd ramp quickly on wireless-specific domain knowledge given the foundation already in place."},"8485103006":{"question_id":"8485103006","priority":6,"boolean_value":1},"8481040006":{"question_id":"8481040006","priority":7,"text_value":"Open to discuss"},"8481041006":{"question_id":"8481041006","priority":8,"boolean_value":0},"8481042006":{"question_id":"8481042006","priority":9,"answer_selected_options_attributes":{"0":{"question_option_id":"17630374006"}}}},"demographic_answers":[],"data_compliance":{},"attachments":{},"from_job_board_renderer":true,"employments":[{"start_date":{"month":null,"year":null},"end_date":{"month":null,"year":null},"current":false}],"phone":"+13468040227","resume_url":"https://grnhse-prod-jben-us-west-2.s3.us-west-2.amazonaws.com/stash/applications/resumes/1782832841217-ricddn4pp28-fbe675967be098f249c2b5eae761a16c","resume_url_filename":"Cyrus_Shekari_Resume_mettel_4685748006_v2.pdf","cover_letter_url":"https://grnhse-prod-jben-us-west-2.s3.us-west-2.amazonaws.com/stash/applications/resumes/1782832856317-ldayeedpw7-c3c972fc114c0556c1edebf623977a50","cover_letter_url_filename":"Cyrus_Shekari_CoverLetter_mettel-4685748006.pdf","gender":"3","race":"8","veteran_status":"3","disability_status":"3","educations":[{"school_name_id":null,"degree_id":null,"discipline_id":null,"start_date":{"month":null,"year":null},"end_date":{"month":null,"year":null}}],"mapped_url_token":null,"appcast_click_id":null,"time_zone":"UTC"},"security_code":"8uEXtjtn","fingerprint":"b364ae8d3b015d68149ada1d4affd9701e1890f8"}
